<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Export PDF - Sommeils</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            font-size: 12px;
            color: #136163;
        }

        h1 {
            text-align: center;
            margin-bottom: 20px;
            color: #136163;
        }

        .meta {
            margin-bottom: 16px;
            font-size: 11px;
            color: #18848e;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            border: 1px solid #b3ecf1;
            padding: 8px;
            text-align: left;
        }

        th {
            background: #b3ecf1;
            color: #136163;
            font-weight: bold;
        }

        tr:nth-child(even) {
            background: #f6fcfd;
        }
    </style>
</head>
<body>
<h1>Liste des sommeils</h1>

<div class="meta">
    Date d’export : {{ "now"|date("d/m/Y H:i") }}
</div>

<table>
    <thead>
    <tr>
        <th>Date</th>
        <th>Heure coucher</th>
        <th>Heure réveil</th>
        <th>Durée</th>
        <th>Qualité</th>
        <th>Humeur réveil</th>
    </tr>
    </thead>
    <tbody>
    {% for sommeil in sommeils %}
        <tr>
            <td>{{ sommeil.dateNuit ? sommeil.dateNuit|date('d/m/Y') : '—' }}</td>
            <td>{{ sommeil.heureCoucher ?? '—' }}</td>
            <td>{{ sommeil.heureReveil ?? '—' }}</td>
            <td>{{ sommeil.dureeSommeil ?? '—' }}</td>
            <td>{{ sommeil.qualite ?? '—' }}</td>
            <td>{{ sommeil.humeurReveil ?? '—' }}</td>
        </tr>
    {% else %}
        <tr>
            <td colspan="6">Aucun sommeil trouvé.</td>
        </tr>
    {% endfor %}
    </tbody>
</table>
</body>
</html>