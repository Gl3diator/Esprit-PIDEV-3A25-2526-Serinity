{% extends 'base.html.twig' %}
{% block title %}{{ reve.titre }} — Sleep Tracker{% endblock %}

{% block body %}

    <nav class="breadcrumb">
        <a href="{{ path('app_reve_index') }}">Rêves</a>
        <span class="breadcrumb__sep">›</span>
        <span class="breadcrumb__current">{{ reve.titre }}</span>
    </nav>

    <header class="page-header">
        <div class="page-header__left">
            <h1 class="page-header__title">💭 {{ reve.titre }}</h1>
            <p class="page-header__subtitle">
                {% if reve.sommeilId is not null %}
                    Nuit du {{ reve.sommeilId.dateNuit ? reve.sommeilId.dateNuit|date('d/m/Y') : '—' }}
                {% endif %}
            </p>
        </div>
        <div style="display:flex;gap:var(--space-3);">
            <a href="{{ path('app_reve_edit', {id: reve.id}) }}" class="btn btn--secondary">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                Modifier
            </a>
            <button type="button" class="btn btn--danger"
                    onclick="document.getElementById('deleteModal').classList.add('open')">Supprimer</button>
        </div>
    </header>

    <div style="display:flex;flex-wrap:wrap;gap:var(--space-2);margin-bottom:var(--space-6);">
        {% if reve.typeReve %}
            {% set typeClass = {'Normal':'muted','Lucide':'primary','Cauchemar':'danger','Prémonitoire':'warning'} %}
            <span class="badge badge--{{ typeClass[reve.typeReve] ?? 'muted' }}">{{ reve.typeReve }}</span>
        {% endif %}
        {% if reve.humeur %}<span class="badge badge--info">{{ reve.humeur }}</span>{% endif %}
        {% if reve.couleur %}<span class="badge badge--success">🎨 Couleur</span>{% endif %}
        {% if reve.recurrent %}<span class="badge badge--warning">↻ Récurrent</span>{% endif %}
    </div>

    <div class="card" style="margin-bottom:var(--space-5);">
        <div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--text-faint);margin-bottom:var(--space-4);">📝 Description</div>
        <p style="color:var(--text-muted);line-height:1.8;white-space:pre-wrap;">{{ reve.description }}</p>
    </div>

    <div class="card" style="margin-bottom:var(--space-5);">
        <div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--text-faint);margin-bottom:var(--space-4);">🔍 Détails</div>
        <div class="detail-grid">
            <div class="detail-item">
                <div class="detail-item__label">Intensité</div>
                <div class="detail-item__value">
                    <div class="intensity-bar" style="margin-top:var(--space-1);">
                        {% for i in 1..10 %}
                            <div class="intensity-dot {% if i <= reve.intensite %}filled{% endif %}"></div>
                        {% endfor %}
                    </div>
                    <span style="font-size:0.8rem;color:var(--text-muted);margin-top:4px;">{{ reve.intensite }}/10</span>
                </div>
            </div>
            <div class="detail-item">
                <div class="detail-item__label">Nuit associée</div>
                <div class="detail-item__value">
                    {% if reve.sommeilId is not null %}
                        <a href="{{ path('app_sommeil_show', {id: reve.sommeilId.id}) }}">
                            {{ reve.sommeilId.dateNuit ? reve.sommeilId.dateNuit|date('d/m/Y') : '—' }}
                        </a>
                    {% else %}—{% endif %}
                </div>
            </div>
            <div class="detail-item">
                <div class="detail-item__label">Créé le</div>
                <div class="detail-item__value">{{ reve.createdAt ? reve.createdAt|date('d/m/Y à H:i') : '—' }}</div>
            </div>
            <div class="detail-item">
                <div class="detail-item__label">Modifié le</div>
                <div class="detail-item__value">{{ reve.updatedAt ? reve.updatedAt|date('d/m/Y à H:i') : '—' }}</div>
            </div>
            {% if reve.emotions %}
                <div class="detail-item detail-item--full">
                    <div class="detail-item__label">Émotions</div>
                    <div class="detail-item__value">{{ reve.emotions }}</div>
                </div>
            {% endif %}
            {% if reve.symboles %}
                <div class="detail-item detail-item--full">
                    <div class="detail-item__label">Symboles</div>
                    <div class="detail-item__value detail-item__value--text">{{ reve.symboles }}</div>
                </div>
            {% endif %}
        </div>
    </div>

    <div class="modal-overlay" id="deleteModal">
        <div class="modal">
            <h2 class="modal__title">Supprimer ce rêve ?</h2>
            <p class="modal__body">« {{ reve.titre }} » sera définitivement supprimé.</p>
            <div class="modal__actions">
                <button type="button" class="btn btn--secondary"
                        onclick="document.getElementById('deleteModal').classList.remove('open')">Annuler</button>
                <form method="post" action="{{ path('app_reve_delete', {id: reve.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ reve.id) }}">
                    <button type="submit" class="btn btn--danger">Supprimer</button>
                </form>
            </div>
        </div>
    </div>

{% endblock %}