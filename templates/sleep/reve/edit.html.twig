{% extends 'base.html.twig' %}
{% block title %}Modifier — {{ reve.titre }} — Sleep Tracker{% endblock %}

{% block body %}

    {% for message in app.flashes('error') %}
        {% if loop.first %}
        <script>
            let errors = [];
            {% endif %}

            errors.push("{{ message|e('js') }}");

            {% if loop.last %}
            alert(errors.join("\n"));
        </script>
        {% endif %}
    {% endfor %}

    <nav class="breadcrumb">
        <a href="{{ path('app_reve_index') }}">Rêves</a>
        <span class="breadcrumb__sep">›</span>
        <a href="{{ path('app_reve_show', {id: reve.id}) }}">{{ reve.titre }}</a>
        <span class="breadcrumb__sep">›</span>
        <span class="breadcrumb__current">Modifier</span>
    </nav>

    <header class="page-header">
        <div class="page-header__left">
            <h1 class="page-header__title">✏️ Modifier le rêve</h1>
            <p class="page-header__subtitle">{{ reve.titre }}</p>
        </div>
    </header>

    <div class="card">
        {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

        {{ form_errors(form) }}

        <div class="form-section">
            <div class="form-section__title">🌙 Général</div>
            <div class="form-grid">

                <div class="form-group form-group--full">
                    {{ form_label(form.sommeilId) }}
                    {{ form_widget(form.sommeilId) }}
                    {{ form_errors(form.sommeilId) }}
                </div>

                <div class="form-group form-group--full">
                    {{ form_label(form.titre) }}
                    {{ form_widget(form.titre) }}
                    {{ form_errors(form.titre) }}
                </div>

                <div class="form-group form-group--full">
                    {{ form_label(form.description) }}
                    {{ form_widget(form.description) }}
                    {{ form_errors(form.description) }}
                </div>

            </div>
        </div>

        <div class="form-section">
            <div class="form-section__title">🏷️ Classification</div>
            <div class="form-grid">

                <div class="form-group">
                    {{ form_label(form.typeReve) }}
                    {{ form_widget(form.typeReve) }}
                    {{ form_errors(form.typeReve) }}
                </div>

                <div class="form-group">
                    {{ form_label(form.humeur) }}
                    {{ form_widget(form.humeur) }}
                    {{ form_errors(form.humeur) }}
                </div>

                <div class="form-group">
                    {{ form_label(form.intensite) }}
                    {{ form_widget(form.intensite, {attr: {id: 'intensite_input'}}) }}
                    {{ form_errors(form.intensite) }}

                    <div class="intensity-bar" id="intensite_preview">
                        {% for i in 1..10 %}
                            <div class="intensity-dot {% if i <= reve.intensite %}filled{% endif %}" data-val="{{ i }}"></div>
                        {% endfor %}
                    </div>
                </div>

                <div class="form-group">
                    {{ form_label(form.emotions) }}
                    {{ form_widget(form.emotions) }}
                    {{ form_errors(form.emotions) }}
                </div>

            </div>
        </div>

        <div class="form-section">
            <div class="form-section__title">🔍 Détails</div>
            <div class="form-grid">

                <div class="form-group form-group--full">
                    {{ form_label(form.symboles) }}
                    {{ form_widget(form.symboles) }}
                    {{ form_errors(form.symboles) }}
                </div>

                <div class="form-group">
                    {{ form_row(form.couleur) }}
                </div>

                <div class="form-group">
                    {{ form_row(form.recurrent) }}
                </div>

            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn--primary">
                ✔ Sauvegarder
            </button>
            <a href="{{ path('app_reve_show', {id: reve.id}) }}" class="btn btn--secondary">Annuler</a>
        </div>

        {{ form_end(form) }}
    </div>

{% endblock %}