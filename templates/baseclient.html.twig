<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Espace Patient{% endblock %}</title>

    <!-- FONT -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

    <!-- ICONS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <style>
        :root {
            --primary: #2F6F6D;
            --secondary: #E6F2F1;
            --accent: #88BDBC;
            --bg: #F9FAFB;
            --text: #1F2933;
            --text2: #5F6C7B;
        }

        body {
            font-family: "Inter";
            background: var(--bg);
            margin: 0;
        }

        /* ===== NAVBAR CLIENT ===== */
        .navbar-client {
            background: white;
            padding: 14px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 4px 14px rgba(0,0,0,0.05);
        }

        .logo {
            font-weight: 800;
            font-size: 20px;
            color: var(--primary);
        }

        .nav-links a {
            margin: 0 10px;
            text-decoration: none;
            color: var(--text2);
            padding: 8px 12px;
            border-radius: 10px;
            transition: 0.2s;
        }

        .nav-links a:hover {
            background: var(--secondary);
            color: var(--primary);
        }

        /* ===== USER ===== */
        .user-box {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .avatar {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            background: linear-gradient(to right, #2F6F6D, #88BDBC);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: bold;
        }

        .logout {
            color: red;
            font-size: 14px;
            text-decoration: none;
        }

        /* ===== CONTENT ===== */
        .container-client {
            max-width: 1200px;
            margin: auto;
            padding: 30px;
        }

        /* ===== CARD ===== */
        .card-client {
            background: white;
            border-radius: 20px;
            padding: 20px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        }

        /* ===== TITLE ===== */
        .page-title {
            font-size: 24px;
            font-weight: bold;
            color: var(--text);
        }

        .subtitle {
            color: var(--text2);
            font-size: 14px;
        }

        /* ===== BUTTON ===== */
        .primary-btn {
            background: var(--primary);
            color: white;
            border: none;
            padding: 10px 18px;
            border-radius: 12px;
            cursor: pointer;
        }

        .primary-btn:hover {
            background: #255d5b;
        }
    </style>
</head>

<body>

<!-- ===== NAVBAR ===== -->
<div class="navbar-client">

    <div class="logo">
        <i class="bi bi-heart-pulse-fill"></i> TheDoctor
    </div>

    <div class="nav-links">
        <a href="/doctors"><i class="bi bi-house"></i> Accueil</a>
        <a href="/mes-rdv"><i class="bi bi-calendar-check"></i> Mes RDV</a>
            
    </div>

    <div class="user-box">

    {% if app.session.get('user_id') %}

        <div class="avatar">
            {{ app.session.get('user_name')|slice(0,1) }}
        </div>

        <div>
            <strong>{{ app.session.get('user_name') }}</strong><br>
            <small>{{ app.session.get('user_email') }}</small>
        </div>

        <a href="{{ path('app_logout') }}" class="logout">
            <i class="bi bi-box-arrow-right"></i>
        </a>

    {% endif %}

</div>

</div>

<!-- ===== CONTENT ===== -->
<div class="container-client">

    {% block body %}{% endblock %}

</div>

</body>
</html>