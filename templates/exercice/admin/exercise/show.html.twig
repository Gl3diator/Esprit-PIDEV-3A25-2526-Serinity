{% extends 'exercice/admin/base_admin.html.twig' %}

{% block title %}Detail de l'exercice{% endblock %}

{% block body %}
    <section class="sn-admin-page">
        <div class="sn-admin-hero">
            <div>
                <span class="sn-admin-kicker">Fiche exercice</span>
                <h1 class="sn-admin-title">{{ exercise.title }}</h1>
                <p class="sn-admin-text">Consultez les informations detaillees de cet exercice.</p>
            </div>
            <div class="sn-admin-actions">
                <a class="sn-btn sn-btn-outline sn-admin-btn" href="{{ path('app_admin_exercise_index') }}">Retour a la liste</a>
                <a class="sn-btn sn-btn-primary sn-admin-btn" href="{{ path('app_admin_exercise_edit', {'id': exercise.id}) }}">Modifier</a>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-8 mb-4 mb-lg-0">
                <article class="sn-admin-panel sn-admin-panel-soft h-100">
                    <div class="sn-admin-panel-header">
                        <h2 class="sn-admin-panel-title">Informations generales</h2>
                    </div>
                    <div class="sn-admin-panel-body">
                        <div class="sn-admin-meta-grid">
                            <div class="sn-admin-meta-card">
                                <p class="sn-admin-eyebrow">Type</p>
                                <span class="sn-admin-pill sn-admin-pill-accent">{{ exercise.type }}</span>
                            </div>
                            <div class="sn-admin-meta-card">
                                <p class="sn-admin-eyebrow">Niveau</p>
                                <span class="sn-admin-pill sn-admin-pill-primary">{{ exercise.level }}</span>
                            </div>
                            <div class="sn-admin-meta-card">
                                <p class="sn-admin-eyebrow">Duree</p>
                                <p class="sn-admin-meta-value">{{ exercise.durationMinutes }} minutes</p>
                            </div>
                        </div>

                        <div class="sn-admin-info sn-admin-info-block">
                            <div>
                                <h3 class="sn-admin-info-title">Description</h3>
                                <p class="sn-admin-copy">{{ exercise.description|default('Aucune description renseignee.') }}</p>
                            </div>
                        </div>

                        <div class="sn-admin-info sn-admin-info-block">
                            <div>
                                <h3 class="sn-admin-info-title">Ressources associees</h3>
                                {% if exercise.resources|length > 0 %}
                                    <div class="sn-admin-stack">
                                        {% for resource in exercise.resources %}
                                            <div>
                                                <p class="sn-admin-copy">{{ resource.title }} ({{ resource.mediaType }})</p>
                                                <a class="sn-admin-action sn-admin-action-ghost" href="{{ path('app_admin_resource_show', {'id': resource.id}) }}">Voir la ressource</a>
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% else %}
                                    <p class="sn-admin-copy">Aucune ressource n'est encore associee a cet exercice.</p>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </article>
            </div>

            <div class="col-lg-4">
                <article class="sn-admin-panel h-100">
                    <div class="sn-admin-panel-header">
                        <h2 class="sn-admin-panel-title">Actions rapides</h2>
                    </div>
                    <div class="sn-admin-panel-body sn-admin-stack">
                        <a class="sn-btn sn-btn-primary sn-admin-btn sn-admin-btn-block" href="{{ path('app_admin_exercise_edit', {'id': exercise.id}) }}">Modifier l'exercice</a>
                        <a class="sn-btn sn-btn-outline sn-admin-btn sn-admin-btn-block" href="{{ path('app_admin_resource_new', {'exercise': exercise.id}) }}">Ajouter une ressource</a>
                        <a class="sn-btn sn-btn-outline sn-admin-btn sn-admin-btn-block" href="{{ path('app_admin_exercise_index') }}">Retour a la liste</a>
                        {{ include('admin/exercise/_delete_form.html.twig') }}
                    </div>
                </article>
            </div>
        </div>
    </section>
{% endblock %}
