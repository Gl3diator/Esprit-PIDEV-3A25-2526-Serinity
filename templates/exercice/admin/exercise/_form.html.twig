{{ form_start(form) }}
    <div class="sn-admin-form">
        {% if form.vars.submitted and not form.vars.valid %}
            <div class="sn-admin-form-errors">{{ form_errors(form) }}</div>
        {% endif %}

        <div class="row">
            <div class="col-md-6">
                <div class="form-group sn-admin-field">
                    {{ form_label(form.title, 'Titre de l exercice', {label_attr: {class: 'sn-admin-label'}}) }}
                    {{ form_widget(form.title, {attr: {class: 'form-control sn-admin-input'}}) }}
                    <div class="sn-admin-form-errors">{{ form_errors(form.title) }}</div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group sn-admin-field">
                    {{ form_label(form.type, 'Type d exercice', {label_attr: {class: 'sn-admin-label'}}) }}
                    {{ form_widget(form.type, {attr: {class: 'form-control sn-admin-input'}}) }}
                    <div class="sn-admin-form-errors">{{ form_errors(form.type) }}</div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="form-group sn-admin-field">
                    {{ form_label(form.level, 'Niveau', {label_attr: {class: 'sn-admin-label'}}) }}
                    {{ form_widget(form.level, {attr: {class: 'form-control sn-admin-input'}}) }}
                    <div class="sn-admin-form-errors">{{ form_errors(form.level) }}</div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group sn-admin-field">
                    {{ form_label(form.durationMinutes, 'Duree (minutes)', {label_attr: {class: 'sn-admin-label'}}) }}
                    {{ form_widget(form.durationMinutes, {attr: {class: 'form-control sn-admin-input'}}) }}
                    <div class="sn-admin-form-errors">{{ form_errors(form.durationMinutes) }}</div>
                </div>
            </div>
        </div>

        <div class="form-group sn-admin-field">
            {{ form_label(form.description, 'Description', {label_attr: {class: 'sn-admin-label'}}) }}
            {{ form_widget(form.description, {attr: {class: 'form-control sn-admin-input sn-admin-textarea'}}) }}
            <div class="sn-admin-form-errors">{{ form_errors(form.description) }}</div>
        </div>

        <div class="sn-admin-form-footer">
            <p class="sn-admin-form-note">Les champs saisis seront utilises immediatement dans l'administration.</p>
            <button class="sn-btn sn-btn-primary sn-admin-btn" type="submit">{{ button_label|default('Enregistrer') }}</button>
        </div>

        {{ form_rest(form) }}
    </div>
{{ form_end(form, {'render_rest': false}) }}
