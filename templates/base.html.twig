{#
templates/base.html.twig — Serinity Sleep
Layout principal : Navbar fixe + Footer complet
#}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{% block meta_description %}Serinity Sleep — Suivez vos nuits, analysez vos rêves.{% endblock %}">
    <title>{% block title %}Serinity Sleep{% endblock %}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="{{ asset('assets/css/nucleo-icons.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/nucleo-svg.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/serinity.css') }}">

    {% block stylesheets %}{% endblock %}
</head>
<body>

{# ════════════════════════════════════════════
   NAVBAR
════════════════════════════════════════════ #}
{% set current_route = app.request.attributes.get('_route') %}

<nav class="sn-navbar" id="sn-navbar" role="navigation" aria-label="Navigation principale">
    <div class="container">

        <a href="{{ path('app_home') }}" class="sn-brand" aria-label="Serinity Sleep — Accueil">
            <img src="{{ asset('assets/img/logo2.png') }}"
                 alt="Serinity logo"
                 width="40" height="40"
                 loading="lazy"
                 class="sn-brand-logo">
            <span class="sn-brand-name">Serinity</span>
        </a>

        <ul class="sn-nav" role="list">

            <li>
                <a href="{{ path('app_sommeil_index') }}"
                   class="sn-nav-link {% if current_route starts with 'app_sommeil' %}active{% endif %}">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                    </svg>
                    Sommeil
                </a>
            </li>

            <li>
                <a href="#" class="sn-nav-link {% if current_route starts with 'app_exercice' %}active{% endif %}">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                    </svg>
                    Exercice
                </a>
            </li>

            <li>
                <a href="#" class="sn-nav-link {% if current_route starts with 'app_humeur' %}active{% endif %}">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="12" cy="12" r="10"/>
                        <path d="M8 14s1.5 2 4 2 4-2 4-2"/>
                        <line x1="9" y1="9" x2="9.01" y2="9"/>
                        <line x1="15" y1="9" x2="15.01" y2="9"/>
                    </svg>
                    Humeur
                </a>
            </li>

            <li>
                <a href="#" class="sn-nav-link {% if current_route starts with 'app_consultation' %}active{% endif %}">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.38 2 2 0 0 1 3.6 1.21h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6.08 6.08l1.15-1.15a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                    </svg>
                    Consultation
                </a>
            </li>

            <li>
                <a href="#" class="sn-nav-link {% if current_route starts with 'app_forum' %}active{% endif %}">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                    </svg>
                    Forum
                </a>
            </li>

        </ul>

        <form class="sn-search" action="{{ path('app_home') }}" method="get" role="search" aria-label="Recherche">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="11" cy="11" r="8"/>
                <line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input type="search" name="q" placeholder="Rechercher…"
                   value="{{ app.request.query.get('q') }}"
                   aria-label="Rechercher dans Serinity Sleep">
        </form>

        <div class="sn-user-btn" role="navigation" aria-label="Menu utilisateur">
            <button class="sn-user-avatar" aria-haspopup="true" aria-expanded="false" aria-label="Mon compte">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                </svg>
            </button>

            <div class="sn-dropdown" role="menu">
                <a href="#" role="menuitem">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" aria-hidden="true">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                        <circle cx="12" cy="7" r="4"/>
                    </svg>
                    Mon profil
                </a>
                <a href="#" role="menuitem">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" aria-hidden="true">
                        <circle cx="12" cy="12" r="3"/>
                        <path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>
                        <path d="M4.93 4.93a10 10 0 0 0 0 14.14"/>
                    </svg>
                    Paramètres
                </a>
                <a href="#" role="menuitem">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" aria-hidden="true">
                        <rect x="3" y="3" width="7" height="7"/>
                        <rect x="14" y="3" width="7" height="7"/>
                        <rect x="14" y="14" width="7" height="7"/>
                        <rect x="3" y="14" width="7" height="7"/>
                    </svg>
                    Tableau de bord
                </a>
                <hr>
                <a href="#" class="danger" role="menuitem">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" aria-hidden="true">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                        <polyline points="16 17 21 12 16 7"/>
                        <line x1="21" y1="12" x2="9" y2="12"/>
                    </svg>
                    Déconnexion
                </a>
            </div>
        </div>

        <button class="sn-mobile-toggle" id="sn-mobile-toggle"
                aria-label="Ouvrir le menu" aria-expanded="false">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24" aria-hidden="true">
                <line x1="3" y1="12" x2="21" y2="12"/>
                <line x1="3" y1="6"  x2="21" y2="6"/>
                <line x1="3" y1="18" x2="21" y2="18"/>
            </svg>
        </button>

    </div>
</nav>

<div class="sn-page-offset" aria-hidden="true"></div>

{# ════════════════════════════════════════════
   FLASH MESSAGES
════════════════════════════════════════════ #}
{% for type, messages in app.flashes %}
    <div class="sn-container" style="padding-top:1rem;" role="alert" aria-live="polite">
        {% for message in messages %}
            <div class="sn-flash {{ type }}">
                {% if type == 'success' %}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18" aria-hidden="true">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                {% else %}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18" aria-hidden="true">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                {% endif %}
                {{ message }}
                <button class="sn-flash-close" onclick="this.parentElement.remove()" aria-label="Fermer">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" aria-hidden="true">
                        <line x1="18" y1="6" x2="6" y2="18"/>
                        <line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                </button>
            </div>
        {% endfor %}
    </div>
{% endfor %}

{# ════════════════════════════════════════════
   CONTENU PRINCIPAL
════════════════════════════════════════════ #}
<main id="main-content" role="main">
    {% block body %}{% endblock %}
</main>

{# ════════════════════════════════════════════
