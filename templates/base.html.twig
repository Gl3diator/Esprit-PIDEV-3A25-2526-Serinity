<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Dashboard{% endblock %}</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

    <!-- BOOTSTRAP -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- ICONS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <style>
        :root {
            --primary: #2F6F6D;
            --secondary: #E6F2F1;
            --accent: #88BDBC;
            --bg: #F9FAFB;
            --text: #1F2933;
        }

        body {
            font-family: "Inter";
            background: var(--bg);
            margin: 0;
        }

        /* NAVBAR */
        .navbar-custom {
            background: linear-gradient(to right, #2F6F6D, #88BDBC);
            padding: 14px 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: white;
        }

        .nav-logo {
            font-weight: 800;
            font-size: 20px;
        }

        .nav-links a {
            color: #e0f2f1;
            margin: 0 10px;
            text-decoration: none;
            padding: 8px 14px;
            border-radius: 8px;
        }

        .nav-links a:hover {
            background: rgba(255,255,255,0.15);
        }

        .logout-btn {
            background: #ef4444;
            padding: 8px 14px;
            border-radius: 10px;
            color: white;
            text-decoration: none;
        }

        /* LAYOUT */
        .layout {
            display: flex;
        }

        /* SIDEBAR */
        .sidebar {
            width: 230px;
            background: var(--primary);
            color: white;
            min-height: 100vh;
            padding: 20px;
        }

        .sidebar h4 {
            margin-bottom: 20px;
        }

        .side-btn {
            display: flex;
            align-items: center;
            gap: 10px;
            color: #d7eeee;
            padding: 10px 12px;
            border-radius: 10px;
            text-decoration: none;
            margin-bottom: 8px;
            font-size: 14px;
        }

        .side-btn:hover {
            background: rgba(255,255,255,0.2);
            color: white;
        }

        /* CONTENT */
        .content {
            flex: 1;
            padding: 25px;
        }

        /* CARD */
        .card-custom {
            background: white;
            border-radius: 18px;
            padding: 20px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        }

        /* TITLE */
        .page-title {
            font-size: 22px;
            font-weight: bold;
        }

        /* BUTTON */
        .primary-btn {
            background: var(--primary);
            color: white;
            padding: 10px 18px;
            border-radius: 12px;
            border: none;
        }

        /* ICON STYLE */
        i {
            font-size: 16px;
        }
    </style>
</head>

<body>

<!-- NAVBAR -->
<div class="navbar-custom">
    <div class="nav-logo">
        <i class="bi bi-heart-pulse-fill"></i> TheDoctor
    </div>

 
    <div>
        {% if app.session.get('user_id') %}
            <i class="bi bi-person-circle"></i>
            {{ app.session.get('user_name') }}

            <a href="{{ path('app_logout') }}" class="logout-btn">
                <i class="bi bi-box-arrow-right"></i>
            </a>
        {% else %}
            <a href="{{ path('app_login') }}" class="primary-btn">
                <i class="bi bi-box-arrow-in-right"></i> Login
            </a>
        {% endif %}
    </div>
</div>

<!-- LAYOUT -->
<div class="layout">

    <!-- SIDEBAR -->
    <div class="sidebar">

        <h4><i class="bi bi-grid-1x2-fill"></i> Menu</h4>

        <a href="{{ path('app_dashboard') }}" class="side-btn">
            <i class="bi bi-speedometer2"></i> Dashboard
        </a>

        <a href="#" class="side-btn">
            <i class="bi bi-calendar2-check"></i> Rendez-vous
        </a>

    

        <a href="#" class="side-btn">
            <i class="bi bi-people-fill"></i> Patients
        </a>

        <a href="#" class="side-btn">
            <i class="bi bi-file-earmark-medical"></i> Consultations
        </a>

    </div>

    <!-- CONTENT -->
    <div class="content">
        {% block body %}{% endblock %}
    </div>

</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>