<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Serinity Sleep{% endblock %}</title>

    {# ── CSS Argon + Font Awesome + Custom ─────────────────── #}
    <link rel="stylesheet" href="{{ asset('assets/css/nucleo-icons.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/nucleo-svg.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/font-awesome.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/argon-design-system.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/serinity-custom.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/app.css') }}">

    {% block stylesheets %}{% endblock %}
</head>
<body>

{% block navbar %}
    <nav class="navbar navbar-expand-lg navbar-serinity">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="{{ path('app_home') }}">
                <img src="{{ asset('assets/img/logo2.png') }}" alt="Serinity Sleep" height="38" class="mr-2">
                Serinity Sleep
            </a>
            <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ml-auto align-items-center">
                    <li class="nav-item {% if app.request.attributes.get('_route') starts with 'app_sommeil' %}active{% endif %}">
                        <a class="nav-link" href="{{ path('app_sommeil_index') }}">
                            <i class="fa fa-bed"></i> Sommeil
                        </a>
                    </li>
                    <li class="nav-item {% if app.request.attributes.get('_route') starts with 'app_reve' %}active{% endif %}">
                        <a class="nav-link" href="{{ path('app_reve_index') }}">
                            <i class="fa fa-cloud"></i> Rêves
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
{% endblock %}

{# ── Flash messages ───────────────────────────────────────── #}
{% for label, messages in app.flashes %}
    <div class="container mt-3">
        {% for message in messages %}
            <div class="alert alert-{{ label == 'success' ? 'success' : 'danger' }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="close" data-dismiss="alert">
                    <span>&times;</span>
                </button>
            </div>
        {% endfor %}
    </div>
{% endfor %}

{% block body %}{% endblock %}

{# ── Scripts Argon ────────────────────────────────────────── #}
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="{{ asset('assets/js/argon-design-system.min.js') }}"></script>

{% block javascripts %}{% endblock %}

</body>
</html>