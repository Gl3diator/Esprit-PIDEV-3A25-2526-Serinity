{# =========================================================
   Bouton flottant traduction — uniquement Sommeil / Rêves
========================================================= #}
{% if current_route starts with 'app_sommeil' or current_route starts with 'app_reve' %}
    {% include 'sleep/_translate_fab.html.twig' %}
{% endif %}

<script>
    (function () {
        "use strict";

        var navbar = document.getElementById('sn-navbar');
        if (navbar) {
            var onScroll = function () {
                navbar.classList.toggle('scrolled', window.scrollY > 20);
            };
            window.addEventListener('scroll', onScroll, { passive: true });
            onScroll();
        }

        var mobileToggle = document.getElementById('sn-mobile-toggle');
        var navList = document.querySelector('.sn-nav');
        var searchBar = document.querySelector('.sn-search');

        if (mobileToggle && navList) {
            mobileToggle.addEventListener('click', function (e) {
                e.stopPropagation();
                var isOpen = this.getAttribute('aria-expanded') === 'true';
                this.setAttribute('aria-expanded', String(!isOpen));
                navList.classList.toggle('open', !isOpen);

                if (searchBar) {
                    searchBar.classList.toggle('sn-search--open', !isOpen);
                }
            });

            document.addEventListener('click', function (e) {
                if (!e.target.closest('.sn-navbar')) {
                    mobileToggle.setAttribute('aria-expanded', 'false');
                    navList.classList.remove('open');

                    if (searchBar) {
                        searchBar.classList.remove('sn-search--open');
                    }
                }
            });
        }

        var userToggle = document.getElementById('sn-user-toggle');
        var dropdown = document.getElementById('sn-dropdown');

        if (userToggle && dropdown) {
            userToggle.addEventListener('click', function (e) {
                e.stopPropagation();
                var isOpen = this.getAttribute('aria-expanded') === 'true';
                this.setAttribute('aria-expanded', String(!isOpen));
                dropdown.classList.toggle('sn-dropdown--open', !isOpen);
            });

            dropdown.addEventListener('click', function (e) {
                e.stopPropagation();
            });

            document.addEventListener('click', function () {
                userToggle.setAttribute('aria-expanded', 'false');
                dropdown.classList.remove('sn-dropdown--open');
            });

            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') {
                    userToggle.setAttribute('aria-expanded', 'false');
                    dropdown.classList.remove('sn-dropdown--open');
                    userToggle.focus();
                }
            });
        }

        document.querySelectorAll('.sn-flash').forEach(function (el) {
            setTimeout(function () {
                el.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
                el.style.opacity = '0';
                el.style.transform = 'translateY(-6px)';
                setTimeout(function () { el.remove(); }, 420);
            }, 5000);
        });

        // =========================================================
        // Translation FAB — Sommeil / Rêves
        // =========================================================
        var trFabBtn = document.getElementById('trFabBtn');
        var trPanel = document.getElementById('trPanel');
        var trPanelClose = document.getElementById('trPanelClose');
        var trRunBtn = document.getElementById('trRunBtn');
        var trResetBtn = document.getElementById('trResetBtn');
        var trTargetLang = document.getElementById('trTargetLang');
        var trStatus = document.getElementById('trStatus');

        function trSetStatus(message, isError) {
            if (!trStatus) return;
            trStatus.hidden = false;
            trStatus.textContent = message || '';
            trStatus.classList.toggle('is-error', !!isError);
        }

        function trClearStatus() {
            if (!trStatus) return;
            trStatus.hidden = true;
            trStatus.textContent = '';
            trStatus.classList.remove('is-error');
        }

        function trOpenPanel() {
            if (!trPanel) return;
            trPanel.hidden = false;
            trPanel.classList.add('open');
        }

        function trClosePanel() {
            if (!trPanel) return;
            trPanel.classList.remove('open');
            trPanel.hidden = true;
            trClearStatus();
        }

        function trCollectNodes() {
            var container = document.getElementById('main-content');
            if (!container) return [];

            var selector = [
                'h1', 'h2', 'h3', 'h4',
                'p',
                'label',
                'th',
                'td',
                'button',
                'a',
                '.badge',
                '.rv-pill',
                '.detail-item__label',
                '.detail-item__value',
                '.page-header__title',
                '.page-header__subtitle',
                '.sl-title',
                '.sl-hero__subtitle',
                '.rv-title',
                '.rv-subtitle'
            ].join(',');

            var elements = Array.prototype.slice.call(container.querySelectorAll(selector));

            return elements.filter(function (el) {
                if (!el) return false;
                if (el.closest('#trFabWrap')) return false;
                if (el.closest('script, style, svg, canvas')) return false;
                if (el.hasAttribute('data-no-translate')) return false;

                var text = (el.textContent || '').trim();

                if (!text || text.length < 2) return false;
                if (/^[\d\s\-–—:/.%+]+$/.test(text)) return false;
                if (text === '×') return false;

                return true;
            });
        }

        async function trTranslatePage() {
            var nodes = trCollectNodes();
            if (!nodes.length) {
                trSetStatus('Aucun texte à traduire sur cette page.', true);
                return;
            }

            var texts = nodes.map(function (node) {
                return node.dataset.originalText || node.textContent.trim();
            });

            var targetLang = trTargetLang ? trTargetLang.value : 'en';

            trSetStatus('Traduction en cours...', false);
            if (trRunBtn) trRunBtn.disabled = true;
            if (trResetBtn) trResetBtn.disabled = true;

            try {
                var response = await fetch('/api/sleep/translate/batch', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        texts: texts,
                        sourceLang: 'fr',
                        targetLang: targetLang
                    })
                });

                var data = await response.json();

                if (!data.success || !Array.isArray(data.translations)) {
                    trSetStatus(data.error || 'Erreur de traduction.', true);
                    return;
                }

                nodes.forEach(function (node, index) {
                    if (!node.dataset.originalText) {
                        node.dataset.originalText = node.textContent.trim();
                    }
                    node.textContent = data.translations[index] || node.dataset.originalText;
                });

                trSetStatus('Traduction terminée.', false);
            } catch (e) {
                trSetStatus('Impossible de traduire pour le moment.', true);
            } finally {
                if (trRunBtn) trRunBtn.disabled = false;
                if (trResetBtn) trResetBtn.disabled = false;
            }
        }

        function trResetPage() {
            var nodes = trCollectNodes();

            nodes.forEach(function (node) {
                if (node.dataset.originalText) {
                    node.textContent = node.dataset.originalText;
                }
            });

            trSetStatus('Texte original restauré.', false);
        }

        if (trFabBtn && trPanel) {
            trFabBtn.addEventListener('click', function () {
                if (trPanel.hidden) {
                    trOpenPanel();
                } else {
                    trClosePanel();
                }
            });
        }

        if (trPanelClose) {
            trPanelClose.addEventListener('click', trClosePanel);
        }

        if (trRunBtn) {
            trRunBtn.addEventListener('click', trTranslatePage);
        }

        if (trResetBtn) {
            trResetBtn.addEventListener('click', trResetPage);
        }

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
                trClosePanel();
            }
        });
    }());
</script>

{% block javascripts %}{% endblock %}
{{ encore_entry_script_tags('app') }}
</body>
</html>
