<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Export PDF Rêves</title>
    <style>
        body { font-family: Arial, sans-serif; }
        table { width: 100%; border-collapse: collapse; }
        th, td { border: 1px solid #ccc; padding: 8px; text-align: left; }
        th { background: #f3f3f3; }
    </style>
</head>
<body>
<h1>Liste des rêves</h1>
<table>
    <thead>
    <tr>
        <th>Date</th>
        <th>Titre</th>
        <th>Type</th>
        <th>Intensité</th>
        <th>Anxiété</th>
    </tr>
    </thead>
    <tbody>
    {% for reve in reves %}
        <tr>
            <td>{{ reve.dateReve ? reve.dateReve|date('Y-m-d') : '' }}</td>
            <td>{{ reve.titre }}</td>
            <td>{{ reve.typeReve }}</td>
            <td>{{ reve.intensite }}</td>
            <td>{{ reve.niveauAnxiete }}</td>
        </tr>
    {% endfor %}
    </tbody>
</table>
</body>
</html>