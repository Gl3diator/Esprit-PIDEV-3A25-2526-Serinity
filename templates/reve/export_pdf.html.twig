<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Export PDF - Rêves</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            font-size: 12px;
            color: #136163;
        }

        h1 {
            text-align: center;
            margin-bottom: 20px;
            color: #136163;
        }

        .meta {
            margin-bottom: 16px;
            font-size: 11px;
            color: #18848e;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            border: 1px solid #b3ecf1;
            padding: 8px;
            text-align: left;
            vertical-align: top;
        }

        th {
            background: #b3ecf1;
            color: #136163;
            font-weight: bold;
        }

        tr:nth-child(even) {
            background: #f6fcfd;
        }
    </style>
</head>
<body>
<h1>Liste des rêves</h1>

<div class="meta">
    Date d’export : {{ "now"|date("d/m/Y H:i") }}
</div>

<table>
    <thead>
    <tr>
        <th>Date</th>
        <th>Titre</th>
        <th>Type</th>
        <th>Humeur</th>
        <th>Intensité</th>
        <th>Couleur</th>
        <th>Récurrent</th>
    </tr>
    </thead>
    <tbody>
    {% for reve in reves %}
        <tr>
            <td>{{ reve.createdAt ? reve.createdAt|date('d/m/Y') : '—' }}</td>
            <td>{{ reve.titre ?? '—' }}</td>
            <td>{{ reve.typeReve ?? '—' }}</td>
            <td>{{ reve.humeur ?? '—' }}</td>
            <td>{{ reve.intensite ?? '—' }}</td>
            <td>{{ reve.couleur ? 'Oui' : 'Non' }}</td>
            <td>{{ reve.recurrent ? 'Oui' : 'Non' }}</td>
        </tr>
    {% else %}
        <tr>
            <td colspan="7">Aucun rêve trouvé.</td>
        </tr>
    {% endfor %}
    </tbody>
</table>
</body>
</html>