{% extends 'base.html.twig' %}
{% block title %}Mes rêves — Sleep Tracker{% endblock %}

{% block body %}

    <header class="sl-header">
        <div class="sl-header-left">
            <h1 class="sl-title">
                <span class="title-icon">💤</span>
                Mes rêves
            </h1>
        </div>

        <div style="display:flex;gap:12px;">
            <a href="{{ path('app_sommeil_index') }}" class="sl-btn sl-btn-outline">← Retour</a>
            <a href="{{ path('app_reve_new') }}" class="sl-btn sl-btn-primary">+ Ajouter un rêve</a>
        </div>
    </header>

    {% if stats.attention %}
        <div class="alert alert-warning mb-3">
            <strong>Attention :</strong> plusieurs cauchemars ont été détectés.
        </div>
    {% endif %}

    <div class="stats-grid mb-4">
        <div class="stat-card">
            <h4>Total rêves</h4>
            <strong>{{ stats.total }}</strong>
        </div>
        <div class="stat-card">
            <h4>Cauchemars</h4>
            <strong>{{ stats.nightmares }}</strong>
        </div>
        <div class="stat-card">
            <h4>Intensité moyenne</h4>
            <strong>{{ stats.avg_intensity }}</strong>
        </div>
    </div>

    <div class="front-mini-charts mb-4">
        <div class="front-mini-chart-card front-mini-chart-card--large">
            <h3>Courbe de l’humeur des rêves</h3>
            <div class="front-mini-chart-wrap front-mini-chart-wrap--large">
                <canvas id="dreamMoodChart"></canvas>
            </div>
        </div>
    </div>

    <form method="get" class="filters-bar mb-4">
        <input
                type="text"
                name="q"
                value="{{ filters.q|default('') }}"
                placeholder="Recherche dynamique..."
        >

        <input
                type="text"
                name="type"
                value="{{ filters.type|default('') }}"
                placeholder="Type de rêve"
        >

        <select name="recurrent">
            <option value="">Tous</option>
            <option value="1" {{ filters.recurrent|default('') == '1' ? 'selected' : '' }}>Récurrent</option>
            <option value="0" {{ filters.recurrent|default('') == '0' ? 'selected' : '' }}>Non récurrent</option>
        </select>

        <input
                type="text"
                name="couleur"
                value="{{ filters.couleur|default('') }}"
                placeholder="Couleur"
        >

        <select name="cauchemars">
            <option value="">Tous</option>
            <option value="1" {{ filters.cauchemars|default('') == '1' ? 'selected' : '' }}>Seulement cauchemars</option>
        </select>

        <select name="sort">
            <option value="date" {{ filters.sort|default('date') == 'date' ? 'selected' : '' }}>Date</option>
            <option value="intensite" {{ filters.sort|default('') == 'intensite' ? 'selected' : '' }}>Intensité</option>
            <option value="titre" {{ filters.sort|default('') == 'titre' ? 'selected' : '' }}>Titre</option>
        </select>

        <button type="submit" class="btn btn--primary">Filtrer</button>
        <a href="{{ path('app_reve_index') }}" class="btn btn--secondary">Réinitialiser</a>
        <a href="{{ path('app_reve_export_csv', app.request.query.all) }}" class="btn btn--secondary">Exporter Excel</a>
        <a href="{{ path('app_reve_export_pdf', app.request.query.all) }}" target="_blank" class="btn btn--secondary">Exporter PDF</a>
    </form>

    {% if reves is empty %}
        <div class="empty-state">
            <div class="empty-state__icon">💭</div>
            <h3>Aucun rêve enregistré</h3>
            <p>Commencez à noter vos rêves pour mieux les analyser.</p>
            <a href="{{ path('app_reve_new') }}" class="btn btn--primary">Ajouter un rêve</a>
        </div>
    {% else %}
        <div class="table-wrapper">
            <table class="sl-table">
                <thead>
                <tr>
                    {% set currentSort = filters.sort %}
                    {% set currentDirection = filters.direction %}

                    {% macro sort_link(label, field, filters, currentSort, currentDirection) %}
                        {% set direction = (currentSort == field and currentDirection == 'ASC') ? 'DESC' : 'ASC' %}

                        <a href="{{ path(app.request.attributes.get('_route'), filters|merge({
                            sort: field,
                            direction: direction
                        })) }}"
                           class="sort-link {{ currentSort == field ? 'active' : '' }}">
                            {{ label }}
                            {% if currentSort == field %}
                                {{ currentDirection == 'ASC' ? '↑' : '↓' }}
                            {% else %}
                                ⇅
                            {% endif %}
                        </a>
                    {% endmacro %}

                    <th>{{ _self.sort_link('Titre', 'titre', filters, currentSort, currentDirection) }}</th>
                    <th>{{ _self.sort_link('Date', 'date', filters, currentSort, currentDirection) }}</th>
                    <th>{{ _self.sort_link('Type', 'type', filters, currentSort, currentDirection) }}</th>
                    <th>{{ _self.sort_link('Humeur', 'humeur', filters, currentSort, currentDirection) }}</th>
                    <th>{{ _self.sort_link('Intensité', 'intensite', filters, currentSort, currentDirection) }}</th>
                    <th>Couleur</th>
                    <th>Récurrent</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for reve in reves %}
                    <tr>
                        <td>
                            <strong>{{ reve.titre }}</strong>
                            {% if reve.recurrent %}
                                <span class="badge badge--warning" style="margin-left:6px;font-size:0.7rem;">↻</span>
                            {% endif %}
                        </td>

                        <td style="font-size:0.85rem;">
                            {% if reve.sommeilId is not null %}
                                <a href="{{ path('app_sommeil_show', {id: reve.sommeilId.id}) }}">
                                    {{ reve.sommeilId.dateNuit ? reve.sommeilId.dateNuit|date('d/m/Y') : '—' }}
                                </a>
                            {% else %}
                                —
                            {% endif %}
                        </td>

                        <td>
                            {% set typeClass = {
                                'Normal':'muted',
                                'Lucide':'primary',
                                'Cauchemar':'danger',
                                'Prémonitoire':'warning'
                            } %}
                            <span class="badge badge--{{ typeClass[reve.typeReve] ?? 'muted' }}">
                                {{ reve.typeReve ?? '—' }}
                            </span>
                        </td>

                        <td>{{ reve.humeur ?? '—' }}</td>

                        <td>
                            <div class="intensity-bar">
                                {% for i in 1..10 %}
                                    <div class="intensity-dot {% if i <= reve.intensite %}filled{% endif %}"></div>
                                {% endfor %}
                            </div>
                        </td>

                        <td>
                            {% if reve.couleur %}
                                <span class="badge badge--info">🎨 Oui</span>
                            {% else %}
                                <span style="color:var(--text-faint);font-size:0.85rem;">N&amp;B</span>
                            {% endif %}
                        </td>

                        <td>
                            {% if reve.recurrent %}
                                <span class="badge badge--warning">Oui</span>
                            {% else %}
                                <span style="color:var(--text-faint);font-size:0.85rem;">Non</span>
                            {% endif %}
                        </td>

                        <td>
                            <div class="actions">
                                <a href="{{ path('app_reve_show', {id: reve.id}) }}" class="btn btn--secondary btn--sm" title="Voir">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                        <circle cx="12" cy="12" r="3"/>
                                    </svg>
                                </a>

                                <a href="{{ path('app_reve_edit', {id: reve.id}) }}" class="btn btn--secondary btn--sm" title="Modifier">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                    </svg>
                                </a>

                                <button
                                        type="button"
                                        class="btn btn--danger btn--sm"
                                        onclick="openDeleteModal('{{ path('app_reve_delete', {id: reve.id}) }}', '{{ reve.titre|escape('js') }}')"
                                        title="Supprimer"
                                >
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <polyline points="3 6 5 6 21 6"/>
                                        <path d="M19 6l-1 14H6L5 6"/>
                                        <path d="M9 6V4h6v2"/>
                                    </svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

    <div class="modal-overlay" id="deleteModal">
        <div class="modal">
            <h2 class="modal__title">Supprimer ce rêve ?</h2>
            <p class="modal__body" id="deleteModalBody">Cette action est irréversible.</p>
            <div class="modal__actions">
                <button type="button" class="btn btn--secondary" onclick="closeDeleteModal()">Annuler</button>
                <form id="deleteForm" method="post">
                    <input type="hidden" name="_token" value="">
                    <button type="submit" class="btn btn--danger">Supprimer</button>
                </form>
            </div>
        </div>
    </div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('assets/js/plugins/chartjs.min.js') }}"></script>
    <script>
        function openDeleteModal(url, label) {
            document.getElementById('deleteForm').action = url;
            document.getElementById('deleteForm').querySelector('[name="_token"]').value = '{{ csrf_token("delete") }}';
            document.getElementById('deleteModalBody').textContent = 'Supprimer "' + label + '" ? Action irréversible.';
            document.getElementById('deleteModal').classList.add('open');
        }

        function closeDeleteModal() {
            document.getElementById('deleteModal').classList.remove('open');
        }

        document.getElementById('deleteModal').addEventListener('click', e => {
            if (e.target === e.currentTarget) closeDeleteModal();
        });

        (() => {
            const dreamMoodChart = document.getElementById('dreamMoodChart');

            if (dreamMoodChart && typeof Chart !== 'undefined') {
                new Chart(dreamMoodChart, {
                    type: 'line',
                    data: {
                        labels: {{ stats.dream_mood_labels|default([])|json_encode|raw }},
                        datasets: [{
                            label: 'Nombre de rêves',
                            data: {{ stats.dream_mood_data|default([])|json_encode|raw }},
                            backgroundColor: 'rgba(99, 102, 241, 0.18)',
                            borderColor: '#6366f1',
                            borderWidth: 3,
                            pointBackgroundColor: '#6366f1',
                            pointBorderColor: '#ffffff',
                            pointBorderWidth: 2,
                            pointRadius: 4,
                            pointHoverRadius: 6,
                            lineTension: 0.42,
                            fill: true
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        legend: {
                            display: false
                        },
                        scales: {
                            yAxes: [{
                                ticks: {
                                    beginAtZero: true,
                                    precision: 0,
                                    fontColor: '#64748b'
                                },
                                gridLines: {
                                    color: 'rgba(148,163,184,0.18)',
                                    drawBorder: false
                                }
                            }],
                            xAxes: [{
                                ticks: {
                                    fontColor: '#64748b'
                                },
                                gridLines: {
                                    display: false,
                                    drawBorder: false
                                }
                            }]
                        },
                        tooltips: {
                            backgroundColor: '#0f172a',
                            titleFontColor: '#ffffff',
                            bodyFontColor: '#e2e8f0',
                            displayColors: false
                        }
                    }
                });
            }
        })();
    </script>
{% endblock %}