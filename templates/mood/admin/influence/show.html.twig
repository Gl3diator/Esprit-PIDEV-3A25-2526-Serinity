{% extends 'mood/admin/base_admin.html.twig' %}

{% block title %}Influence details{% endblock %}
{% block breadcrumb %}Détail influence{% endblock %}

{% block admin_content %}
    <div class="row">
        <div class="col-lg-8 mb-4 mb-lg-0">
            <article class="sn-admin-panel sn-admin-panel-soft h-100">
                <div class="sn-admin-panel-header sn-admin-panel-header-inline">
                    <h2 class="sn-admin-panel-title">Influence details</h2>

                    <div class="sn-admin-actions">
                        <a href="{{ path('app_admin_influence_index') }}" class="sn-btn sn-btn-outline sn-admin-btn">
                            Back to list
                        </a>
                        <a href="{{ path('app_admin_influence_edit', {'id': influence.id}) }}" class="sn-btn sn-btn-primary sn-admin-btn">
                            Edit
                        </a>
                    </div>
                </div>

                <div class="sn-admin-panel-body">
                    <div class="sn-admin-meta-grid">
                        <div class="sn-admin-meta-card">
                            <p class="sn-admin-eyebrow">Id</p>
                            <p class="sn-admin-meta-value">{{ influence.id }}</p>
                        </div>

                        <div class="sn-admin-meta-card">
                            <p class="sn-admin-eyebrow">Name</p>
                            <p class="sn-admin-meta-value">{{ influence.name }}</p>
                        </div>
                    </div>
                </div>
            </article>
        </div>

        <div class="col-lg-4">
            <article class="sn-admin-panel h-100">
                <div class="sn-admin-panel-header">
                    <h2 class="sn-admin-panel-title">Delete influence</h2>
                </div>
                <div class="sn-admin-panel-body">
                    {{ include('mood/admin/influence/_delete_form.html.twig') }}
                </div>
            </article>
        </div>
    </div>
{% endblock %}