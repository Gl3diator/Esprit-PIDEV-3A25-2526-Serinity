{% set currentRoute = app.request.attributes.get('_route') %}

<div class="card shadow">
    <div class="card-header border-0">
        <h3 class="mb-0">Navigation</h3>
    </div>

    <div class="list-group list-group-flush">
        <a href="{{ path('app_admin_dashboard') }}"
           class="list-group-item list-group-item-action {% if currentRoute == 'app_admin_dashboard' %}active{% endif %}">
            Dashboard
        </a>

        <a href="{{ path('app_admin_emotion_index') }}"
           class="list-group-item list-group-item-action {% if currentRoute starts with 'app_admin_emotion_' %}active{% endif %}">
            Manage emotions
        </a>

        <a href="{{ path('app_admin_influence_index') }}"
           class="list-group-item list-group-item-action {% if currentRoute starts with 'app_admin_influence_' %}active{% endif %}">
            Manage influences
        </a>
    </div>
</div>
