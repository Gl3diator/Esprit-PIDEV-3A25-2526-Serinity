{% extends 'base.html.twig' %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('assets/css/tokens.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/front.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/serinity-custom.css') }}">
{% endblock %}

{% block body_class %}sn-theme-front{% endblock %}

{% block title %}Serinity{% endblock %}

{% block body %}
    {% set currentRoute = app.request.attributes.get('_route') %}

    <section class="serinity-mood-shell">
        <div class="container">
            <div class="row">
                {# Sidebar gauche #}
                <aside class="col-lg-3 mb-4 mb-lg-0">
                    <div class="serinity-mood-sidebar shadow-sm">
                        <div class="serinity-mood-sidebar-header">
                            <h4 class="mb-1">Mood Control</h4>
                            <p class="mb-0">Navigation rapide</p>
                        </div>

                        <nav class="serinity-mood-nav" aria-label="Navigation mood">
                            <a class="serinity-mood-link {% if currentRoute starts with 'app_mood_entry_' and currentRoute != 'app_mood_entry_summary' %}active{% endif %}"
                               href="{{ path('app_mood_entry_index') }}">
                                <i class="ni ni-satisfied mr-2"></i>
                                <span>Mood entries</span>
                            </a>

                            <a class="serinity-mood-link {% if currentRoute == 'app_mood_entry_summary' %}active{% endif %}"
                               href="{{ path('app_mood_entry_summary') }}">
                                <i class="ni ni-chart-bar-32 mr-2"></i>
                                <span>Mood summary</span>
                            </a>

                            <a class="serinity-mood-link {% if currentRoute starts with 'app_journal_entry_' %}active{% endif %}"
                               href="{{ path('app_journal_entry_index') }}">
                                <i class="ni ni-single-copy-04 mr-2"></i>
                                <span>Journal</span>
                            </a>
                        </nav>
                    </div>
                </aside>

                {# Contenu principal droite #}
                <div class="col-lg-9">
                    <div class="serinity-mood-hero mb-4">
                        <div class="row align-items-center">
                            <div class="col-lg-8">
                                <h1 class="serinity-mood-title mb-3">
                                    {% block front_title %}Serinity{% endblock %}
                                </h1>
                                <p class="serinity-mood-subtitle mb-0">
                                    {% block front_subtitle %}Your personal space for mood tracking and reflection.{% endblock %}
                                </p>
                            </div>

                            <div class="col-lg-4 mt-4 mt-lg-0">
                                <div class="serinity-mood-summary shadow-sm">
                                    {% block front_summary %}
                                        <h4 class="mb-2">Mood Control</h4>
                                        <p class="mb-0">Track mood entries, review influences, and write journal reflections.</p>
                                    {% endblock %}
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="serinity-mood-content">
                        {% block front_content %}{% endblock %}
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer class="serinity-landing-footer">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-12 text-center">
                    <p class="mb-0">© 2026 Serinity. All rights reserved.</p>
                </div>
            </div>
        </div>
    </footer>
{% endblock %}
