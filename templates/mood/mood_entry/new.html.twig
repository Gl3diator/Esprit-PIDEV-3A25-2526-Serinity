{% extends 'mood/front/base_front.html.twig' %}

{% block title %}New mood entry{% endblock %}
{% block front_title %}New mood entry{% endblock %}
{% block front_subtitle %}Create a new mood record with emotions and influences.{% endblock %}
{% block front_summary %}
    <h4 class="text-white mb-2">New mood entry</h4>
    <p class="mb-0">Keep it simple and focus on what you feel right now.</p>
{% endblock %}

{% block front_content %}
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card serinity-surface-card shadow-sm mb-4">
                <div class="card-header border-0 bg-white">
                    <div class="row align-items-center">
                        <div class="col">
                            <h3 class="mb-0">Create new mood entry</h3>
                        </div>
                        <div class="col text-right">
                            <a href="{{ path('app_mood_entry_index') }}" class="btn btn-sm btn-outline-primary">
                                Back to list
                            </a>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4">
                    {{ include('mood/mood_entry/_form.html.twig') }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
