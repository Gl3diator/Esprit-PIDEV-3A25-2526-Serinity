{% extends 'mood/front/base_front.html.twig' %}

{% block title %}Mood entries{% endblock %}
{% block front_title %}Mood entries{% endblock %}
{% block front_subtitle %}Search, create, and review your mood entry history.{% endblock %}
{% block front_summary %}
    <h4 class="text-white mb-2">Mood history</h4>
    <p class="mb-0">Use filters, add a new entry, and browse grouped mood history.</p>
{% endblock %}

{% block front_content %}
    <div class="serinity-top-cards-wrap">
        <div class="row mb-5">
            <div class="col-lg-8 mb-3">
                <div class="card shadow border-0 card-lift--hover h-100">
                    <div class="card-header bg-transparent pb-0">
                        <h6 class="text-uppercase text-muted ls-1 mb-1">Filters</h6>
                        <h3 class="mb-0">Find mood entries</h3>
                    </div>

                    <div class="card-body">
                        <form method="get" action="{{ path('app_mood_entry_index') }}">
                            <div class="row serinity-filter-row">
    <div class="col-lg-8 col-md-12 mb-3">
        <label class="form-control-label">Search</label>
        <div class="input-group input-group-alternative">
            <div class="input-group-prepend">
                <span class="input-group-text">
                    <i class="ni ni-zoom-split-in"></i>
                </span>
            </div>
            <input
                type="text"
                name="q"
                value="{{ search }}"
                class="form-control"
                placeholder="Search by type, emotion, or influence"
            >
        </div>
    </div>

    <div class="col-lg-4 col-md-6 mb-3">
        <label class="form-control-label">Type</label>
        <select name="type" class="form-control">
            <option value="">All</option>
            <option value="DAY" {{ selected_type == 'DAY' ? 'selected' : '' }}>Day</option>
            <option value="MOMENT" {{ selected_type == 'MOMENT' ? 'selected' : '' }}>Moment</option>
        </select>
    </div>
</div>

<div class="row serinity-filter-submit-row">
    <div class="col">
        <button type="submit" class="btn btn-primary btn-icon serinity-filter-submit-btn">
            <span class="btn-inner--icon"><i class="ni ni-check-bold"></i></span>
            <span class="btn-inner--text">Apply</span>
        </button>
    </div>
</div>

                            {% if search or selected_type %}
                                <div class="mt-2">
                                    <a href="{{ path('app_mood_entry_index') }}" class="btn btn-sm btn-outline-secondary btn-icon">
                                        <span class="btn-inner--icon"><i class="ni ni-refresh"></i></span>
                                        <span class="btn-inner--text">Reset filters</span>
                                    </a>
                                </div>
                            {% endif %}
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 mb-3">
                <div class="card shadow border-0 card-lift--hover h-100">
                    <div class="card-body d-flex flex-column justify-content-center text-center py-5">
                        <div class="icon icon-shape bg-gradient-primary text-white rounded-circle shadow mb-4 mx-auto">
                            <i class="ni ni-fat-add"></i>
                        </div>
                        <h4 class="mb-2">New mood entry</h4>
                        <p class="text-muted mb-4">
                            Add a new mood record with emotions and influences.
                        </p>
                        <a href="{{ path('app_mood_entry_new') }}" class="btn btn-primary btn-icon mx-auto">
                            <span class="btn-inner--icon"><i class="ni ni-fat-add"></i></span>
                            <span class="btn-inner--text">Create new entry</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {% for group in grouped_entries %}
        <div class="mb-3 mt-4">
            <h3 class="mb-0">{{ group.label }}</h3>
        </div>

        {% for mood_entry in group.entries %}
            <div class="card serinity-surface-card shadow-sm mb-4">
                <div class="card-body p-4">
                    <div class="row align-items-start">
                        <div class="col-md-9">
                            <div class="d-flex flex-wrap align-items-center mb-3">
                                <h3 class="mb-0 mr-3">
                                    {% if mood_entry.momentType == 'DAY' %}
                                        Day
                                    {% else %}
                                        Moment
                                    {% endif %}
                                </h3>

                                <span class="badge badge-pill badge-info mr-2 serinity-badge-pill">
                                    {{ mood_entry.momentType }}
                                </span>

                                <span class="badge badge-pill badge-primary serinity-badge-pill">
                                    {{ mood_entry.moodLevel }}/5
                                </span>
                            </div>

                            <div class="mb-3">
                                <h5 class="text-muted serinity-section-title">Emotions</h5>
                                {% for emotion in mood_entry.emotions %}
                                    <span class="badge badge-secondary mr-1 mb-1 serinity-card-tag">
                                        {{ emotion.name }}
                                    </span>
                                {% else %}
                                    <span class="text-muted">-</span>
                                {% endfor %}
                            </div>

                            <div class="mb-0">
                                <h5 class="text-muted serinity-section-title">Influences</h5>
                                {% for influence in mood_entry.influences %}
                                    <span class="badge badge-default mr-1 mb-1 serinity-card-tag">
                                        {{ influence.name }}
                                    </span>
                                {% else %}
                                    <span class="text-muted">-</span>
                                {% endfor %}
                            </div>
                        </div>

                        <div class="col-md-3 text-md-right mt-3 mt-md-0">
                            <a href="{{ path('app_mood_entry_show', {'id': mood_entry.id}) }}" class="btn btn-sm btn-info mb-2">
                                Show
                            </a>
                            <a href="{{ path('app_mood_entry_edit', {'id': mood_entry.id}) }}" class="btn btn-sm btn-secondary mb-2">
                                Edit
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    {% else %}
        <div class="card serinity-surface-card shadow-sm">
            <div class="card-body text-center text-muted">
                No records found for the selected filters.
            </div>
        </div>
    {% endfor %}
{% endblock %}
