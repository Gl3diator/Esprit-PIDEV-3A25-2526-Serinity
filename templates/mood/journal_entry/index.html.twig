{% extends 'mood/front/base_front.html.twig' %}

{% block title %}Journal entries{% endblock %}
{% block front_title %}Journal entries{% endblock %}
{% block front_subtitle %}Write, search, and review your personal reflections.{% endblock %}
{% block front_summary %}
    <h4 class="text-white mb-2">Journal history</h4>
    <p class="mb-0">Search your entries by title or content and keep your writing habit visible.</p>
{% endblock %}

{% block front_content %}
    <div class="serinity-top-cards-wrap">
        <div class="row mb-4">
            <div class="col-lg-4 col-md-6 mb-3">
                <div class="card shadow-sm border-0 card-lift--hover h-100">
                    <div class="card-body py-4">
                        <div class="icon icon-shape bg-info text-white rounded-circle shadow mb-3">
                            <i class="ni ni-time-alarm"></i>
                        </div>
                        <h6 class="text-uppercase text-muted mb-1">Current streak</h6>
                        <h2 class="mb-0">{{ current_streak }}</h2>
                        <p class="text-sm text-muted mb-0">Consecutive days up to today</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 col-md-6 mb-3">
                <div class="card shadow-sm border-0 card-lift--hover h-100">
                    <div class="card-body py-4">
                        <div class="icon icon-shape bg-warning text-white rounded-circle shadow mb-3">
                            <i class="ni ni-trophy"></i>
                        </div>
                        <h6 class="text-uppercase text-muted mb-1">Longest streak</h6>
                        <h2 class="mb-0">{{ longest_streak }}</h2>
                        <p class="text-sm text-muted mb-0">Best streak of all time</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 col-md-12 mb-3">
    <div class="card shadow-sm border-0 card-lift--hover h-100">
        <div class="card-body py-4">
            <div class="icon icon-shape bg-success text-white rounded-circle shadow mb-3">
                <i class="ni ni-calendar-grid-58"></i>
            </div>
            <h6 class="text-uppercase text-muted mb-1">Most entries in 1 day</h6>
            <h2 class="mb-0">{{ max_entries_one_day }}</h2>
            <p class="text-sm text-muted mb-0">Highest number of journal entries written on a single day</p>
        </div>
    </div>
</div>
        </div>

        <div class="row mb-5">
            <div class="col-lg-8 mb-3">
                <div class="card shadow border-0 card-lift--hover h-100">
                    <div class="card-header bg-transparent pb-0">
                        <h6 class="text-uppercase text-muted ls-1 mb-1">Search</h6>
                        <h3 class="mb-0">Find journal entries</h3>
                    </div>

                    <div class="card-body">
                        <form method="get" action="{{ path('app_journal_entry_index') }}">
                            <div class="row serinity-filter-row">
                                <div class="col-lg-12 mb-3">
                                    <label class="form-control-label">Search</label>
                                    <div class="input-group input-group-alternative">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text">
                                                <i class="ni ni-zoom-split-in"></i>
                                            </span>
                                        </div>
                                        <input
                                            type="text"
                                            name="q"
                                            value="{{ search }}"
                                            class="form-control"
                                            placeholder="Search by title or content"
                                        >
                                    </div>
                                </div>
                            </div>

                            <div class="row serinity-filter-submit-row">
                                <div class="col">
                                    <button type="submit" class="btn btn-primary btn-icon serinity-filter-submit-btn">
                                        <span class="btn-inner--icon"><i class="ni ni-check-bold"></i></span>
                                        <span class="btn-inner--text">Apply</span>
                                    </button>
                                </div>
                            </div>

                            {% if search %}
                                <div class="mt-2">
                                    <a href="{{ path('app_journal_entry_index') }}" class="btn btn-sm btn-outline-secondary btn-icon">
                                        <span class="btn-inner--icon"><i class="ni ni-refresh"></i></span>
                                        <span class="btn-inner--text">Reset search</span>
                                    </a>
                                </div>
                            {% endif %}
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 mb-3">
                <div class="card shadow border-0 card-lift--hover h-100">
                    <div class="card-body d-flex flex-column justify-content-center text-center py-5">
                        <div class="icon icon-shape bg-gradient-primary text-white rounded-circle shadow mb-4 mx-auto">
                            <i class="ni ni-fat-add"></i>
                        </div>
                        <h4 class="mb-2">New journal entry</h4>
                        <p class="text-muted mb-4">
                            Add a new reflection and keep your journal history up to date.
                        </p>
                        <a href="{{ path('app_journal_entry_new') }}" class="btn btn-primary btn-icon mx-auto">
                            <span class="btn-inner--icon"><i class="ni ni-fat-add"></i></span>
                            <span class="btn-inner--text">Create new entry</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {% for group in grouped_entries %}
        <div class="mb-3 mt-4">
            <h3 class="mb-0">{{ group.label }}</h3>
        </div>

        {% for journal_entry in group.entries %}
            <div class="card serinity-surface-card shadow-sm mb-4">
                <div class="card-body p-4">
                    <div class="row align-items-start">
                        <div class="col-md-9">
                            <h3 class="mb-2">{{ journal_entry.title }}</h3>
                            <p class="text-muted mb-0">
                                {{ journal_entry.content|length > 220
                                    ? journal_entry.content|slice(0, 220) ~ '...'
                                    : journal_entry.content }}
                            </p>
                        </div>

                        <div class="col-md-3 text-md-right mt-3 mt-md-0">
                            <a href="{{ path('app_journal_entry_show', {'id': journal_entry.id}) }}" class="btn btn-sm btn-info mb-2">
                                Show
                            </a>
                            <a href="{{ path('app_journal_entry_edit', {'id': journal_entry.id}) }}" class="btn btn-sm btn-secondary mb-2">
                                Edit
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="card serinity-surface-card shadow-sm">
                <div class="card-body text-center text-muted">
                    No journal entries found.
                </div>
            </div>
        {% endfor %}
    {% else %}
        <div class="card serinity-surface-card shadow-sm">
            <div class="card-body text-center text-muted">
                No journal entries found.
            </div>
        </div>
    {% endfor %}
{% endblock %}
