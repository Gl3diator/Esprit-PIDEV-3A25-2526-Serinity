{% extends 'base.html.twig' %}
{% block title %}Mes nuits — Serinity Sleep{% endblock %}

{% block body %}

    <header class="sl-header">
        <div class="sl-header-left">
            <h1 class="sl-title">
                <span class="title-icon">🌙</span>
                Mes nuits de sommeil
            </h1>
        </div>

        <div style="display:flex;gap:12px;">
            <a href="{{ path('app_sommeil_index') }}" class="sl-btn sl-btn-outline">← Retour</a>
            <a href="{{ path('app_sommeil_new') }}" class="sl-btn sl-btn-primary">+ Ajouter une nuit</a>
        </div>
    </header>

    <section class="front-stats-block">
        <div class="stats-grid-front stats-grid-front--small">
            <div class="stats-card-front">
                <span>Total nuits</span>
                <strong>{{ stats.total ?? sommeils|length }}</strong>
            </div>
            <div class="stats-card-front">
                <span>Durée moyenne</span>
                <strong>{{ stats.avg_duration ?? 0 }} h</strong>
            </div>
            <div class="stats-card-front">
                <span>Qualité moyenne</span>
                <strong>{{ stats.avg_quality ?? 0 }}%</strong>
            </div>
        </div>

        <div class="front-mini-charts">
            <div class="front-mini-chart-card">
                <h3>Qualité du sommeil</h3>
                <div class="front-mini-chart-wrap">
                    <canvas id="frontSleepQualityChart"></canvas>
                </div>
            </div>

            <div class="front-mini-chart-card">
                <h3>Durée de sommeil</h3>
                <div class="front-mini-chart-wrap">
                    <canvas id="frontSleepDurationChart"></canvas>
                </div>
            </div>

            <div class="front-mini-chart-card">
                <h3>Humeur au réveil</h3>
                <div class="front-mini-chart-wrap">
                    <canvas id="frontWakeMoodChart"></canvas>
                </div>
            </div>
        </div>
    </section>

    <form method="get" class="filters-bar mb-4">
        <input
                type="text"
                name="q"
                value="{{ filters.q|default('') }}"
                placeholder="Recherche dynamique..."
        >

        <select name="qualite">
            <option value="">Toutes les qualités</option>
            <option value="Excellente" {{ filters.qualite|default('') == 'Excellente' ? 'selected' : '' }}>Excellente</option>
            <option value="Bonne" {{ filters.qualite|default('') == 'Bonne' ? 'selected' : '' }}>Bonne</option>
            <option value="Moyenne" {{ filters.qualite|default('') == 'Moyenne' ? 'selected' : '' }}>Moyenne</option>
            <option value="Mauvaise" {{ filters.qualite|default('') == 'Mauvaise' ? 'selected' : '' }}>Mauvaise</option>
        </select>

        <input
                type="text"
                name="humeur"
                value="{{ filters.humeur|default('') }}"
                placeholder="Humeur réveil"
        >

        <select name="insuffisant">
            <option value="">Tous</option>
            <option value="1" {{ filters.insuffisant|default('') == '1' ? 'selected' : '' }}>
                Sommeil insuffisant
            </option>
        </select>

        <input type="hidden" name="_sort" value="{{ filters.sort|default('date_nuit') }}">
        <input type="hidden" name="_direction" value="{{ filters.direction|default('DESC') }}">

        <button type="submit" class="btn btn--primary">Filtrer</button>
        <a href="{{ path('app_sommeil_list') }}" class="btn btn--secondary">Réinitialiser</a>
        <a href="{{ path('app_sommeil_export_csv', app.request.query.all) }}" class="btn btn--secondary">Exporter Excel</a>
        <a href="{{ path('app_sommeil_export_pdf', app.request.query.all) }}" target="_blank" class="btn btn--secondary">Exporter PDF</a>
    </form>

    {% if sommeils is empty %}
        <div class="empty-state">
            <div class="empty-state__icon">🌙</div>
            <h3>Aucune nuit enregistrée</h3>
            <p>Commencez à suivre votre sommeil.</p>
            <a href="{{ path('app_sommeil_new') }}" class="btn btn--primary">Ajouter une nuit</a>
        </div>
    {% else %}
        {% set currentSort = filters.sort|default('date_nuit') %}
        {% set currentDirection = filters.direction|default('DESC') %}

        <div class="table-wrapper">
            <table class="sl-table">
                <thead>
                <tr>
                    <th>
                        {% set nextDirection = (currentSort == 'date_nuit' and currentDirection == 'ASC') ? 'DESC' : 'ASC' %}
                        <a href="{{ path('app_sommeil_list', app.request.query.all|merge({sort: 'date_nuit', direction: nextDirection})) }}"
                           class="sort-link {{ currentSort == 'date_nuit' ? 'active' : '' }}">
                            Date
                            {% if currentSort == 'date_nuit' %}
                                {{ currentDirection == 'ASC' ? '↑' : '↓' }}
                            {% else %}
                                ⇅
                            {% endif %}
                        </a>
                    </th>

                    <th>Coucher</th>
                    <th>Réveil</th>

                    <th>
                        {% set nextDirection = (currentSort == 'duree' and currentDirection == 'ASC') ? 'DESC' : 'ASC' %}
                        <a href="{{ path('app_sommeil_list', app.request.query.all|merge({sort: 'duree', direction: nextDirection})) }}"
                           class="sort-link {{ currentSort == 'duree' ? 'active' : '' }}">
                            Durée
                            {% if currentSort == 'duree' %}
                                {{ currentDirection == 'ASC' ? '↑' : '↓' }}
                            {% else %}
                                ⇅
                            {% endif %}
                        </a>
                    </th>

                    <th>
                        {% set nextDirection = (currentSort == 'qualite' and currentDirection == 'ASC') ? 'DESC' : 'ASC' %}
                        <a href="{{ path('app_sommeil_list', app.request.query.all|merge({sort: 'qualite', direction: nextDirection})) }}"
                           class="sort-link {{ currentSort == 'qualite' ? 'active' : '' }}">
                            Qualité
                            {% if currentSort == 'qualite' %}
                                {{ currentDirection == 'ASC' ? '↑' : '↓' }}
                            {% else %}
                                ⇅
                            {% endif %}
                        </a>
                    </th>

                    <th>Humeur réveil</th>
                    <th>Badges</th>

                    <th>
                        {% set nextDirection = (currentSort == 'interruptions' and currentDirection == 'ASC') ? 'DESC' : 'ASC' %}
                        <a href="{{ path('app_sommeil_list', app.request.query.all|merge({sort: 'interruptions', direction: nextDirection})) }}"
                           class="sort-link {{ currentSort == 'interruptions' ? 'active' : '' }}">
                            Actions
                            {% if currentSort == 'interruptions' %}
                                {{ currentDirection == 'ASC' ? '↑' : '↓' }}
                            {% else %}
                                ⇅
                            {% endif %}
                        </a>
                    </th>
                </tr>
                </thead>
                <tbody>
                {% for sommeil in sommeils %}
                    <tr>
                        <td>
                            <strong>{{ sommeil.dateNuit ? sommeil.dateNuit|date('d/m/Y') : '—' }}</strong>
                        </td>

                        <td>{{ sommeil.heureCoucher ?? '—' }}</td>

                        <td>{{ sommeil.heureReveil ?? '—' }}</td>

                        <td>
                            {% if sommeil.dureeSommeil %}
                                {{ sommeil.dureeSommeil }}h
                            {% else %}
                                —
                            {% endif %}
                        </td>

                        <td>
                            {% set qClass = {
                                'Excellente':'primary',
                                'Bonne':'primary',
                                'Moyenne':'warning',
                                'Mauvaise':'danger'
                            } %}
                            {% if sommeil.qualite %}
                                <span class="badge badge--{{ qClass[sommeil.qualite] ?? 'muted' }}">
                                    {{ sommeil.qualite }}
                                </span>
                            {% else %}
                                —
                            {% endif %}
                        </td>

                        <td>{{ sommeil.humeurReveil ?? '—' }}</td>

                        <td>
                            {% if sommeil.isSommeilInsuffisant %}
                                <span class="badge badge-warning">Sommeil insuffisant</span>
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </td>

                        <td>
                            <div class="actions">
                                <a href="{{ path('app_sommeil_show', {id: sommeil.id}) }}"
                                   class="btn btn--secondary btn--sm"
                                   title="Voir">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                        <circle cx="12" cy="12" r="3"/>
                                    </svg>
                                </a>

                                <a href="{{ path('app_sommeil_edit', {id: sommeil.id}) }}"
                                   class="btn btn--secondary btn--sm"
                                   title="Modifier">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                    </svg>
                                </a>

                                <button type="button"
                                        class="btn btn--danger btn--sm"
                                        onclick="openDeleteModal('{{ path('app_sommeil_delete', {id: sommeil.id}) }}', '{{ sommeil.dateNuit ? sommeil.dateNuit|date('d/m/Y')|escape('js') : sommeil.id }}')"
                                        title="Supprimer">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <polyline points="3 6 5 6 21 6"/>
                                        <path d="M19 6l-1 14H6L5 6"/>
                                        <path d="M9 6V4h6v2"/>
                                    </svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

    <div class="modal-overlay" id="deleteModal">
        <div class="modal">
            <h2 class="modal__title">Supprimer cette nuit ?</h2>
            <p class="modal__body" id="deleteModalBody">Cette action est irréversible.</p>
            <div class="modal__actions">
                <button type="button" class="btn btn--secondary" onclick="closeDeleteModal()">Annuler</button>
                <form id="deleteForm" method="post">
                    <input type="hidden" name="_token" value="">
                    <button type="submit" class="btn btn--danger">Supprimer</button>
                </form>
            </div>
        </div>
    </div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('assets/js/plugins/chartjs.min.js') }}"></script>
    <script>
        function openDeleteModal(url, label) {
            document.getElementById('deleteForm').action = url;
            document.getElementById('deleteForm').querySelector('[name="_token"]').value = '{{ csrf_token("delete") }}';
            document.getElementById('deleteModalBody').textContent = 'Supprimer la nuit du "' + label + '" ? Action irréversible.';
            document.getElementById('deleteModal').classList.add('open');
        }

        function closeDeleteModal() {
            document.getElementById('deleteModal').classList.remove('open');
        }

        document.getElementById('deleteModal').addEventListener('click', function(e) {
            if (e.target === e.currentTarget) {
                closeDeleteModal();
            }
        });

        (() => {
            const sleepPie = document.getElementById('frontSleepQualityChart');
            if (sleepPie && typeof Chart !== 'undefined') {
                new Chart(sleepPie, {
                    type: 'doughnut',
                    data: {
                        labels: ['Excellente', 'Bonne', 'Moyenne', 'Mauvaise'],
                        datasets: [{
                            data: [
                                {{ stats.qualite_excellente|default(0) }},
                                {{ stats.qualite_bonne|default(0) }},
                                {{ stats.qualite_moyenne|default(0) }},
                                {{ stats.qualite_mauvaise|default(0) }}
                            ],
                            backgroundColor: ['#1d4ed8', '#3b82f6', '#93c5fd', '#dbeafe'],
                            borderWidth: 0
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        cutoutPercentage: 70,
                        legend: {
                            position: 'bottom',
                            labels: {
                                boxWidth: 10,
                                padding: 12,
                                fontColor: '#64748b'
                            }
                        }
                    }
                });
            }

            const sleepDurationChart = document.getElementById('frontSleepDurationChart');
            if (sleepDurationChart && typeof Chart !== 'undefined') {
                new Chart(sleepDurationChart, {
                    type: 'line',
                    data: {
                        labels: {{ stats.sleep_duration_labels|default([])|json_encode|raw }},
                        datasets: [{
                            data: {{ stats.sleep_duration_data|default([])|json_encode|raw }},
                            backgroundColor: 'rgba(59, 130, 246, 0.28)',
                            borderColor: '#4f46e5',
                            borderWidth: 2,
                            pointRadius: 0,
                            pointHoverRadius: 4,
                            lineTension: 0.42,
                            fill: true
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        legend: { display: false },
                        elements: {
                            line: {
                                tension: 0.42
                            }
                        },
                        scales: {
                            yAxes: [{
                                ticks: {
                                    beginAtZero: true,
                                    fontColor: '#64748b'
                                },
                                gridLines: {
                                    color: 'rgba(148,163,184,0.14)',
                                    drawBorder: false
                                }
                            }],
                            xAxes: [{
                                ticks: {
                                    fontColor: '#64748b'
                                },
                                gridLines: {
                                    display: false,
                                    drawBorder: false
                                }
                            }]
                        },
                        tooltips: {
                            backgroundColor: '#0f172a',
                            titleFontColor: '#ffffff',
                            bodyFontColor: '#e2e8f0',
                            displayColors: false
                        }
                    }
                });
            }

            const wakeBar = document.getElementById('frontWakeMoodChart');
            if (wakeBar && typeof Chart !== 'undefined') {
                new Chart(wakeBar, {
                    type: 'bar',
                    data: {
                        labels: {{ stats.wake_mood_labels|default([])|json_encode|raw }},
                        datasets: [{
                            data: {{ stats.wake_mood_data|default([])|json_encode|raw }},
                            backgroundColor: '#94a3b8',
                            hoverBackgroundColor: '#64748b',
                            borderWidth: 0,
                            borderRadius: 8,
                            barPercentage: 0.58,
                            categoryPercentage: 0.72
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        legend: { display: false },
                        scales: {
                            yAxes: [{
                                ticks: {
                                    beginAtZero: true,
                                    precision: 0,
                                    fontColor: '#64748b'
                                },
                                gridLines: {
                                    color: 'rgba(148,163,184,0.18)',
                                    drawBorder: false
                                }
                            }],
                            xAxes: [{
                                ticks: {
                                    fontColor: '#64748b'
                                },
                                gridLines: {
                                    display: false,
                                    drawBorder: false
                                }
                            }]
                        }
                    }
                });
            }
        })();
    </script>
{% endblock %}