{% extends 'base.html.twig' %}
{% block title %}Mes nuits — Serinity Sleep{% endblock %}

{% block body %}

    <header class="page-header">
        <div class="page-header__left">
            <h1 class="page-header__title">🌙 Mes nuits de sommeil</h1>
            <p class="page-header__subtitle">{{ sommeils|length }} nuit{{ sommeils|length > 1 ? 's' : '' }} enregistrée{{ sommeils|length > 1 ? 's' : '' }}</p>
        </div>
        <div style="display:flex;gap:var(--space-3);">
            <a href="{{ path('app_sommeil_index') }}" class="btn btn--secondary">← Retour</a>
            <a href="{{ path('app_sommeil_new') }}" class="btn btn--primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Ajouter une nuit
            </a>
        </div>
    </header>

    {% if sommeils is empty %}
        <div class="empty-state">
            <div class="empty-state__icon">🌙</div>
            <h3>Aucune nuit enregistrée</h3>
            <p>Commencez à suivre votre sommeil.</p>
            <a href="{{ path('app_sommeil_new') }}" class="btn btn--primary">Ajouter une nuit</a>
        </div>
    {% else %}
        <div class="table-wrapper">
            <table class="table">
                <thead>
                <tr>
                    <th>Date</th><th>Coucher</th><th>Réveil</th>
                    <th>Durée</th><th>Qualité</th><th>Humeur réveil</th><th>Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for sommeil in sommeils %}
                    <tr>
                        <td><strong>{{ sommeil.dateNuit ? sommeil.dateNuit|date('d/m/Y') : '—' }}</strong></td>
                        <td>{{ sommeil.heureCoucher ?? '—' }}</td>
                        <td>{{ sommeil.heureReveil ?? '—' }}</td>
                        <td>{% if sommeil.dureeSommeil %}{{ sommeil.dureeSommeil }}h{% else %}—{% endif %}</td>
                        <td>
                            {% set qClass = {'Excellente':'primary','Bonne':'primary','Moyenne':'warning','Mauvaise':'danger'} %}
                            {% if sommeil.qualite %}<span class="badge badge--{{ qClass[sommeil.qualite] ?? 'muted' }}">{{ sommeil.qualite }}</span>
                            {% else %}—{% endif %}
                        </td>
                        <td>{{ sommeil.humeurReveil ?? '—' }}</td>
                        <td>
                            <div class="actions">
                                <a href="{{ path('app_sommeil_show', {id: sommeil.id}) }}" class="btn btn--secondary btn--sm" title="Voir">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                </a>
                                <a href="{{ path('app_sommeil_edit', {id: sommeil.id}) }}" class="btn btn--secondary btn--sm" title="Modifier">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                </a>
                                <button type="button" class="btn btn--danger btn--sm"
                                        onclick="openDeleteModal('{{ path('app_sommeil_delete', {id: sommeil.id}) }}', '{{ sommeil.dateNuit ? sommeil.dateNuit|date('d/m/Y')|escape('js') : sommeil.id }}')"
                                        title="Supprimer">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M9 6V4h6v2"/></svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

    <div class="modal-overlay" id="deleteModal">
        <div class="modal">
            <h2 class="modal__title">Supprimer cette nuit ?</h2>
            <p class="modal__body" id="deleteModalBody">Cette action est irréversible.</p>
            <div class="modal__actions">
                <button type="button" class="btn btn--secondary" onclick="closeDeleteModal()">Annuler</button>
                <form id="deleteForm" method="post">
                    <input type="hidden" name="_token" value="">
                    <button type="submit" class="btn btn--danger">Supprimer</button>
                </form>
            </div>
        </div>
    </div>

{% endblock %}

{% block javascripts %}
    <script>
        function openDeleteModal(url, label) {
            document.getElementById('deleteForm').action = url;
            document.getElementById('deleteForm').querySelector('[name="_token"]').value = '{{ csrf_token("delete") }}';
            document.getElementById('deleteModalBody').textContent = 'Supprimer la nuit du "' + label + '" ? Action irréversible.';
            document.getElementById('deleteModal').classList.add('open');
        }
        function closeDeleteModal() { document.getElementById('deleteModal').classList.remove('open'); }
        document.getElementById('deleteModal').addEventListener('click', e => { if (e.target === e.currentTarget) closeDeleteModal(); });
    </script>
{% endblock %}