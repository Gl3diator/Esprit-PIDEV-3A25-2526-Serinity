{% extends 'base.html.twig' %}
{% block title %}Mes nuits — Serinity Sleep{% endblock %}

{% block body %}

    <header class="page-header sl-header">
        <div class="page-header__left sl-header-left">

            <h1 class="sl-title">
                <span class="title-icon">🌙</span>
                <span class="sl-title-text">Mes nuits de sommeil</span>
            </h1>


        </div>

        <div style="display:flex;gap:12px;">
            <a href="{{ path('app_sommeil_index') }}" class="sl-btn sl-btn-outline">
                ← Retour
            </a>

            <a href="{{ path('app_sommeil_new') }}" class="sl-btn sl-btn-primary">
                + Ajouter une nuit
            </a>
        </div>
    </header>

    {# =========================
       BLOC STATISTIQUES
       ========================= #}
    <div class="stats-grid mb-4">
        <div class="stat-card">
            <h4>Total sommeils</h4>
            <strong>{{ stats.total }}</strong>
        </div>
        <div class="stat-card">
            <h4>Durée moyenne</h4>
            <strong>{{ stats.avg_duration }} h</strong>
        </div>
        <div class="stat-card">
            <h4>Sommeils insuffisants</h4>
            <strong>{{ stats.insufficient }}</strong>
        </div>
    </div>

    {# =========================
       FORMULAIRE FILTRES
       ========================= #}
    <form method="get" class="filters-bar mb-4">
        <input
                type="text"
                name="q"
                value="{{ filters.q|default('') }}"
                placeholder="Recherche dynamique..."
        >

        <select name="qualite">
            <option value="">Toutes les qualités</option>
            <option value="Excellente" {{ filters.qualite|default('') == 'Excellente' ? 'selected' : '' }}>Excellente</option>
            <option value="Bonne" {{ filters.qualite|default('') == 'Bonne' ? 'selected' : '' }}>Bonne</option>
            <option value="Moyenne" {{ filters.qualite|default('') == 'Moyenne' ? 'selected' : '' }}>Moyenne</option>
            <option value="Mauvaise" {{ filters.qualite|default('') == 'Mauvaise' ? 'selected' : '' }}>Mauvaise</option>
        </select>

        <input
                type="text"
                name="humeur"
                value="{{ filters.humeur|default('') }}"
                placeholder="Humeur réveil"
        >

        <select name="insuffisant">
            <option value="">Tous</option>
            <option value="1" {{ filters.insuffisant|default('') == '1' ? 'selected' : '' }}>
                Sommeil insuffisant
            </option>
        </select>

        <select name="sort">
            <option value="date_nuit" {{ filters.sort|default('date_nuit') == 'date_nuit' ? 'selected' : '' }}>Date</option>
            <option value="duree" {{ filters.sort|default('') == 'duree' ? 'selected' : '' }}>Durée</option>
            <option value="qualite" {{ filters.sort|default('') == 'qualite' ? 'selected' : '' }}>Qualité</option>
            <option value="interruptions" {{ filters.sort|default('') == 'interruptions' ? 'selected' : '' }}>Interruptions</option>
        </select>

        <select name="direction">
            <option value="DESC" {{ filters.direction|default('DESC') == 'DESC' ? 'selected' : '' }}>Décroissant</option>
            <option value="ASC" {{ filters.direction|default('') == 'ASC' ? 'selected' : '' }}>Croissant</option>
        </select>

        <button type="submit" class="btn btn--primary">Filtrer</button>
        <a href="{{ path('app_sommeil_index') }}" class="btn btn--secondary">Réinitialiser</a>
        <a href="{{ path('app_sommeil_export_csv', app.request.query.all) }}" class="btn btn--secondary">Exporter Excel</a>
        <a href="{{ path('app_sommeil_export_pdf', app.request.query.all) }}" target="_blank" class="btn btn--secondary">Exporter PDF</a>
    </form>

    {% if sommeils is empty %}
        <div class="empty-state">
            <div class="empty-state__icon">🌙</div>
            <h3>Aucune nuit enregistrée</h3>
            <p>Commencez à suivre votre sommeil.</p>
            <a href="{{ path('app_sommeil_new') }}" class="btn btn--primary">Ajouter une nuit</a>
        </div>
    {% else %}
        <div class="table-wrapper">
            <table class="table">
                <thead>
                <tr>
                    <th>Date</th>
                    <th>Coucher</th>
                    <th>Réveil</th>
                    <th>Durée</th>
                    <th>Qualité</th>
                    <th>Humeur réveil</th>
                    <th>Badges</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for sommeil in sommeils %}
                    <tr>
                        <td>
                            <strong>{{ sommeil.dateNuit ? sommeil.dateNuit|date('d/m/Y') : '—' }}</strong>
                        </td>
                        <td>{{ sommeil.heureCoucher ?? '—' }}</td>
                        <td>{{ sommeil.heureReveil ?? '—' }}</td>
                        <td>
                            {% if sommeil.dureeSommeil %}
                                {{ sommeil.dureeSommeil }}h
                            {% else %}
                                —
                            {% endif %}
                        </td>
                        <td>
                            {% set qClass = {
                                'Excellente':'primary',
                                'Bonne':'primary',
                                'Moyenne':'warning',
                                'Mauvaise':'danger'
                            } %}
                            {% if sommeil.qualite %}
                                <span class="badge badge--{{ qClass[sommeil.qualite] ?? 'muted' }}">
                                    {{ sommeil.qualite }}
                                </span>
                            {% else %}
                                —
                            {% endif %}
                        </td>
                        <td>{{ sommeil.humeurReveil ?? '—' }}</td>

                        <td>
                            {% if sommeil.isSommeilInsuffisant %}
                                <span class="badge badge-warning">Sommeil insuffisant</span>
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </td>

                        <td>
                            <div class="actions">
                                <a href="{{ path('app_sommeil_show', {id: sommeil.id}) }}"
                                   class="btn btn--secondary btn--sm"
                                   title="Voir">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                        <circle cx="12" cy="12" r="3"/>
                                    </svg>
                                </a>

                                <a href="{{ path('app_sommeil_edit', {id: sommeil.id}) }}"
                                   class="btn btn--secondary btn--sm"
                                   title="Modifier">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                    </svg>
                                </a>

                                <button type="button"
                                        class="btn btn--danger btn--sm"
                                        onclick="openDeleteModal('{{ path('app_sommeil_delete', {id: sommeil.id}) }}', '{{ sommeil.dateNuit ? sommeil.dateNuit|date('d/m/Y')|escape('js') : sommeil.id }}')"
                                        title="Supprimer">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <polyline points="3 6 5 6 21 6"/>
                                        <path d="M19 6l-1 14H6L5 6"/>
                                        <path d="M9 6V4h6v2"/>
                                    </svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

    <div class="modal-overlay" id="deleteModal">
        <div class="modal">
            <h2 class="modal__title">Supprimer cette nuit ?</h2>
            <p class="modal__body" id="deleteModalBody">Cette action est irréversible.</p>
            <div class="modal__actions">
                <button type="button" class="btn btn--secondary" onclick="closeDeleteModal()">Annuler</button>
                <form id="deleteForm" method="post">
                    <input type="hidden" name="_token" value="">
                    <button type="submit" class="btn btn--danger">Supprimer</button>
                </form>
            </div>
        </div>
    </div>

{% endblock %}

{% block javascripts %}
    <script>
        function openDeleteModal(url, label) {
            document.getElementById('deleteForm').action = url;
            document.getElementById('deleteForm').querySelector('[name="_token"]').value = '{{ csrf_token("delete") }}';
            document.getElementById('deleteModalBody').textContent = 'Supprimer la nuit du "' + label + '" ? Action irréversible.';
            document.getElementById('deleteModal').classList.add('open');
        }

        function closeDeleteModal() {
            document.getElementById('deleteModal').classList.remove('open');
        }

        document.getElementById('deleteModal').addEventListener('click', function(e) {
            if (e.target === e.currentTarget) {
                closeDeleteModal();
            }
        });
    </script>
{% endblock %}