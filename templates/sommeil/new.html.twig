{% extends 'base.html.twig' %}
{% block title %}Nouvelle nuit — Sleep Tracker{% endblock %}

{% block body %}

    {% for message in app.flashes('error') %}
        {% if loop.first %}
        <script>
            let errors = [];
            {% endif %}

            errors.push("{{ message|e('js') }}");

            {% if loop.last %}
            alert(errors.join("\n"));
        </script>
        {% endif %}
    {% endfor %}

    <div class="sleep-create-page">

        <nav class="breadcrumb">
            <a href="{{ path('app_sommeil_index') }}">Sommeil</a>
            <span>›</span>
            <span>Nouvelle nuit</span>
        </nav>

        <header class="page-header">
            <h1 class="page-title">🌙 Nouvelle nuit</h1>
            <p class="page-subtitle">Enregistrez votre nuit de sommeil</p>
        </header>

        <div class="sleep-card">

            {{ form_start(form, {
                attr: {
                    class: 'sleep-form',
                    novalidate: 'novalidate'
                }
            }) }}

            {% if form.vars.submitted and not form.vars.valid %}
                <script>
                    let errors = [];

                    {% for field in form %}
                    {% for error in field.vars.errors %}
                    errors.push("{{ error.message|e('js') }}");
                    {% endfor %}
                    {% endfor %}

                    {% for error in form.vars.errors %}
                    errors.push("{{ error.message|e('js') }}");
                    {% endfor %}

                    if (errors.length > 0) {
                        alert(errors.join("\n"));
                    }
                </script>
            {% endif %}

            {{ form_errors(form) }}

            <div class="form-section">
                <h3>⏰ Horaires</h3>
                <div class="form-grid">

                    <div>
                        {{ form_label(form.dateNuit) }}
                        {{ form_widget(form.dateNuit) }}
                        {{ form_errors(form.dateNuit) }}
                    </div>

                    <div>
                        {{ form_label(form.heureCoucher) }}
                        {{ form_widget(form.heureCoucher) }}
                        {{ form_errors(form.heureCoucher) }}
                    </div>

                    <div>
                        {{ form_label(form.heureReveil) }}
                        {{ form_widget(form.heureReveil) }}
                        {{ form_errors(form.heureReveil) }}
                    </div>

                    <div>
                        {{ form_label(form.dureeSommeil) }}
                        {{ form_widget(form.dureeSommeil) }}
                        {{ form_errors(form.dureeSommeil) }}
                    </div>

                </div>
            </div>

            <div class="form-section">
                <h3>⭐ Qualité & ressenti</h3>
                <div class="form-grid">

                    <div>
                        {{ form_label(form.qualite) }}
                        {{ form_widget(form.qualite) }}
                        {{ form_errors(form.qualite) }}
                    </div>

                    <div>
                        {{ form_label(form.humeurReveil) }}
                        {{ form_widget(form.humeurReveil) }}
                        {{ form_errors(form.humeurReveil) }}
                    </div>

                    <div>
                        {{ form_label(form.interruptions) }}
                        {{ form_widget(form.interruptions) }}
                        {{ form_errors(form.interruptions) }}
                    </div>

                </div>
            </div>

            <div class="form-section">
                <h3>🏠 Environnement</h3>
                <div class="form-grid">

                    <div>
                        {{ form_label(form.environnement) }}
                        {{ form_widget(form.environnement) }}
                        {{ form_errors(form.environnement) }}
                    </div>

                    <div>
                        {{ form_label(form.temperature) }}
                        {{ form_widget(form.temperature) }}
                        {{ form_errors(form.temperature) }}
                    </div>

                    <div>
                        {{ form_label(form.bruitNiveau) }}
                        {{ form_widget(form.bruitNiveau) }}
                        {{ form_errors(form.bruitNiveau) }}
                    </div>

                </div>
            </div>

            <div class="form-section">
                <h3>📝 Notes</h3>

                {{ form_label(form.commentaire) }}
                {{ form_widget(form.commentaire) }}
                {{ form_errors(form.commentaire) }}

            </div>

            <div class="form-actions">
                <button type="submit" class="btn-primary">
                    ✔ Enregistrer
                </button>

                <a href="{{ path('app_sommeil_index') }}" class="btn-secondary">
                    Annuler
                </a>
            </div>

            {{ form_end(form) }}

        </div>

    </div>

{% endblock %}