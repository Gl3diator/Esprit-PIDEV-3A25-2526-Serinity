<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Export PDF Sommeils</title>
    <style>
        body { font-family: Arial, sans-serif; }
        table { width: 100%; border-collapse: collapse; }
        th, td { border: 1px solid #ccc; padding: 8px; text-align: left; }
        th { background: #f3f3f3; }
    </style>
</head>
<body>
<h1>Liste des sommeils</h1>
<table>
    <thead>
    <tr>
        <th>Date</th>
        <th>Durée</th>
        <th>Qualité</th>
        <th>Humeur</th>
        <th>Statut</th>
    </tr>
    </thead>
    <tbody>
    {% for sommeil in sommeils %}
        <tr>
            <td>{{ sommeil.dateNuit ? sommeil.dateNuit|date('Y-m-d') : '' }}</td>
            <td>{{ sommeil.dureeSommeil }}</td>
            <td>{{ sommeil.qualite }}</td>
            <td>{{ sommeil.humeurReveil }}</td>
            <td>{{ sommeil.isSommeilInsuffisant ? 'Sommeil insuffisant' : 'Normal' }}</td>
        </tr>
    {% endfor %}
    </tbody>
</table>
</body>
</html>