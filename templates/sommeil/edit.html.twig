{% extends 'base.html.twig' %}
{% block title %}Modifier nuit — Sleep Tracker{% endblock %}

{% block body %}

    <nav class="breadcrumb">
        <a href="{{ path('app_sommeil_index') }}">Sommeil</a>
        <span class="breadcrumb__sep">›</span>
        <a href="{{ path('app_sommeil_show', {id: sommeil.id}) }}">
            {{ sommeil.dateNuit ? sommeil.dateNuit|date('d/m/Y') : '#' ~ sommeil.id }}
        </a>
        <span class="breadcrumb__sep">›</span>
        <span class="breadcrumb__current">Modifier</span>
    </nav>

    <header class="page-header">
        <div class="page-header__left">
            <h1 class="page-header__title">✏️ Modifier la nuit</h1>
            <p class="page-header__subtitle">{{ sommeil.dateNuit ? sommeil.dateNuit|date('d/m/Y') : '' }}</p>
        </div>
    </header>

    <div class="card">
        {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

        <div class="form-section">
            <div class="form-section__title">⏰ Horaires</div>
            <div class="form-grid">
                <div class="form-group">
                    {{ form_label(form.dateNuit, 'Date de la nuit', {label_attr: {class: 'form-label'}}) }}
                    {{ form_widget(form.dateNuit, {attr: {class: 'form-control'}}) }}
                    {{ form_errors(form.dateNuit) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.heureCoucher, 'Heure de coucher', {label_attr: {class: 'form-label'}}) }}
                    {{ form_widget(form.heureCoucher, {attr: {class: 'form-control'}}) }}
                    {{ form_errors(form.heureCoucher) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.heureReveil, 'Heure de réveil', {label_attr: {class: 'form-label'}}) }}
                    {{ form_widget(form.heureReveil, {attr: {class: 'form-control'}}) }}
                    {{ form_errors(form.heureReveil) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.dureeSommeil, 'Durée (heures)', {label_attr: {class: 'form-label'}}) }}
                    {{ form_widget(form.dureeSommeil, {attr: {class: 'form-control'}}) }}
                    {{ form_errors(form.dureeSommeil) }}
                </div>
            </div>
        </div>

        <div class="form-section">
            <div class="form-section__title">⭐ Qualité & ressenti</div>
            <div class="form-grid">
                <div class="form-group">
                    {{ form_label(form.qualite, 'Qualité', {label_attr: {class: 'form-label'}}) }}
                    {{ form_widget(form.qualite, {attr: {class: 'form-control'}}) }}
                    {{ form_errors(form.qualite) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.humeurReveil, 'Humeur au réveil', {label_attr: {class: 'form-label'}}) }}
                    {{ form_widget(form.humeurReveil, {attr: {class: 'form-control'}}) }}
                    {{ form_errors(form.humeurReveil) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.interruptions, 'Interruptions', {label_attr: {class: 'form-label'}}) }}
                    {{ form_widget(form.interruptions, {attr: {class: 'form-control', min: '0'}}) }}
                    {{ form_errors(form.interruptions) }}
                </div>
            </div>
        </div>

        <div class="form-section">
            <div class="form-section__title">🏠 Environnement</div>
            <div class="form-grid">
                <div class="form-group">
                    {{ form_label(form.environnement, 'Environnement', {label_attr: {class: 'form-label'}}) }}
                    {{ form_widget(form.environnement, {attr: {class: 'form-control'}}) }}
                    {{ form_errors(form.environnement) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.temperature, 'Température (°C)', {label_attr: {class: 'form-label'}}) }}
                    {{ form_widget(form.temperature, {attr: {class: 'form-control'}}) }}
                    {{ form_errors(form.temperature) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.bruitNiveau, 'Niveau de bruit', {label_attr: {class: 'form-label'}}) }}
                    {{ form_widget(form.bruitNiveau, {attr: {class: 'form-control'}}) }}
                    {{ form_errors(form.bruitNiveau) }}
                </div>
            </div>
        </div>

        <div class="form-section">
            <div class="form-section__title">📝 Notes</div>
            <div class="form-group">
                {{ form_label(form.commentaire, 'Commentaire', {label_attr: {class: 'form-label'}}) }}
                {{ form_widget(form.commentaire, {attr: {class: 'form-control', rows: '4'}}) }}
                {{ form_errors(form.commentaire) }}
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn--primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                Sauvegarder
            </button>
            <a href="{{ path('app_sommeil_show', {id: sommeil.id}) }}" class="btn btn--secondary">Annuler</a>
        </div>

        {{ form_end(form) }}
    </div>

{% endblock %}