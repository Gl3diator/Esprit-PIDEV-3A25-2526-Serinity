{% extends 'access_control/layout.html.twig' %}

{% block title %}Admin Sommeil — Serinity{% endblock %}

{% block stylesheets %}
    {{ parent() }}

    <link rel="stylesheet" href="{{ asset('assets/css/tokens.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/admin.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/serinity-custom.css') }}">

    <style>
        body::before,
        body::after,
        .ac-shell::before,
        .ac-shell::after,
        .ac-main::before,
        .ac-main::after,
        .ac-content::before,
        .ac-content::after,
        .adm-page-header::before,
        .adm-page-header::after {
            display: none !important;
            content: none !important;
            background: none !important;
            mask: none !important;
            -webkit-mask: none !important;
        }

        .ac-main {
            width: calc(100vw - 320px) !important;
            max-width: calc(100vw - 320px) !important;
            overflow-x: hidden !important;
        }

        .ac-content {
            padding: 28px 32px !important;
            max-width: 100% !important;
            overflow-x: hidden !important;
        }

        .adm-powerbi-card {
            width: 100% !important;
            max-width: 100% !important;
        }

        .adm-powerbi-frame-wrapper {
            width: 100% !important;
            height: 560px !important;
            min-height: 560px !important;
            background: #fff !important;
            overflow: hidden !important;
        }

        .adm-powerbi-iframe {
            width: 100% !important;
            height: 100% !important;
            border: 0 !important;
            display: block !important;
        }

        .adm-table-card {
            width: 100% !important;
            overflow: hidden !important;
        }

        .adm-table-wrap {
            width: 100% !important;
            overflow-x: auto !important;
        }

        .adm-table {
            width: 100% !important;
            min-width: 900px !important;
            table-layout: fixed !important;
        }

        .adm-table th,
        .adm-table td {
            padding: 14px 16px !important;
            font-size: 14px !important;
            white-space: nowrap !important;
        }

        .adm-table th:nth-child(1),
        .adm-table td:nth-child(1) {
            width: 55px !important;
        }

        .adm-col-actions {
            width: 180px !important;
            min-width: 180px !important;
            text-align: center !important;
        }

        .adm-actions-group {
            display: flex !important;
            justify-content: center !important;
            align-items: center !important;
            gap: 8px !important;
            flex-wrap: nowrap !important;
        }

        .adm-col-actions .adm-btn,
        .adm-col-actions button {
            min-width: 72px !important;
            height: 36px !important;
            padding: 0 10px !important;
            display: inline-flex !important;
            justify-content: center !important;
            align-items: center !important;
            font-size: 13px !important;
            line-height: 1 !important;
            white-space: nowrap !important;
            border-radius: 10px !important;
            margin: 0 !important;
        }

        .adm-pagination-wrap {
            margin: 18px 0 28px !important;
            display: flex !important;
            justify-content: center !important;
        }

        .adm-title-icon.mod-sommeil-icon {
            display: none !important;
        }

        .adm-title-icon,
        .adm-kpi-icon,
        .adm-powerbi-card-icon {
            width: 42px !important;
            height: 42px !important;
            min-width: 42px !important;
            max-width: 42px !important;
            overflow: hidden !important;
        }

        .adm-title-icon svg,
        .adm-kpi-icon svg,
        .adm-powerbi-card-icon svg {
            width: 22px !important;
            height: 22px !important;
            max-width: 22px !important;
            max-height: 22px !important;
        }
    </style>
{% endblock %}

{% block content %}
    <div class="ac-app-layout">
        {% include 'access_control/components/_sidebar.html.twig' with { items: nav } %}

        <div class="ac-main">
            {% include 'access_control/components/_topbar.html.twig' with {
                title: 'Sleep',
                subtitle: 'Dashboard sommeil et rêves',
                username: userName
            } %}

            <main class="ac-content" id="main-content">

                <div class="adm-page-header">
                    <div>
                        <h1 class="adm-page-title">
                            <span>Gestion Sommeil &amp; Rêves</span>
                        </h1>
                    </div>
                </div>

                <div class="adm-kpi-grid adm-kpi-small">
                    <div class="adm-kpi-card kpi-sommeil">
                        <div class="adm-kpi-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
                                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                            </svg>
                        </div>
                        <div class="adm-kpi-info">
                            <span class="adm-kpi-value">{{ kpis.total_sommeils }}</span>
                            <span class="adm-kpi-label">Entrées Sommeil</span>
                        </div>
                    </div>

                    <div class="adm-kpi-card kpi-reves">
                        <div class="adm-kpi-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
                                <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                                <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
                            </svg>
                        </div>
                        <div class="adm-kpi-info">
                            <span class="adm-kpi-value">{{ kpis.total_reves }}</span>
                            <span class="adm-kpi-label">Rêves enregistrés</span>
                        </div>
                    </div>

                    <div class="adm-kpi-card kpi-avg">
                        <div class="adm-kpi-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
                                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                            </svg>
                        </div>
                        <div class="adm-kpi-info">
                            <span class="adm-kpi-value">{{ kpis.moyenne_duree }}h</span>
                            <span class="adm-kpi-label">Durée moyenne</span>
                        </div>
                    </div>

                    <div class="adm-kpi-card kpi-quality">
                        <div class="adm-kpi-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
                                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                            </svg>
                        </div>
                        <div class="adm-kpi-info">
                            <span class="adm-kpi-value">{{ kpis.moyenne_qualite }}%</span>
                            <span class="adm-kpi-label">Qualité moy.</span>
                        </div>
                    </div>
                </div>

                <section class="adm-stacked-section">
                    <div class="adm-section-heading">
                        <h2 class="adm-section-block-title">Statistiques Sommeil</h2>
                        <span class="adm-section-count">{{ kpis.total_sommeils }} entrée(s)</span>
                    </div>

                    <div class="adm-powerbi-card">
                        <div class="adm-powerbi-card-header">
                            <span class="adm-powerbi-card-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
                                    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                                </svg>
                            </span>
                            <h3 class="adm-powerbi-card-title">Analyse Power BI — Sommeil</h3>
                            <span class="adm-powerbi-badge">Power BI</span>
                        </div>

                        <div class="adm-powerbi-frame-wrapper">
                            <iframe
                                    title="sommeil"
                                    src="https://app.powerbi.com/reportEmbed?reportId=0e045a52-f58f-44af-ae60-1134d355b44f&autoAuth=true&ctid=604f1a96-cbe8-43f8-abbf-f8eaf5d85730"
                                    frameborder="0"
                                    allowfullscreen="true"
                                    loading="lazy"
                                    class="adm-powerbi-iframe">
                            </iframe>
                        </div>
                    </div>

                    <div class="adm-table-card">
                        <div class="adm-table-header">
                            <div class="adm-table-header-left">
                                <span class="adm-table-dot dot-sommeil"></span>
                                <h2 class="adm-table-title">Tableau Sommeil</h2>
                                <span class="adm-table-count" id="sleepCount">{{ kpis.total_sommeils }} entrée(s)</span>
                            </div>

                            <div class="adm-table-header-right" style="gap: 0.75rem; flex-wrap: wrap;">
                                <div class="adm-search-mini">
                                    <input type="search" id="sleepSearch" placeholder="Rechercher..." aria-label="Rechercher une entrée sommeil">
                                </div>

                                <select id="sleepStatusFilter" class="adm-filter-select">
                                    <option value="">Tous les statuts</option>
                                    <option value="bon">Bon</option>
                                    <option value="moyen">Moyen</option>
                                    <option value="à améliorer">À améliorer</option>
                                </select>
                            </div>
                        </div>

                        <div class="adm-table-wrap">
                            <table class="adm-table" id="sleepTable">
                                <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Utilisateur</th>
                                    <th>Date</th>
                                    <th>Durée</th>
                                    <th>Qualité</th>
                                    <th>Heure coucher</th>
                                    <th>Heure réveil</th>
                                    <th>Statut</th>
                                    <th class="adm-col-actions">Actions</th>
                                </tr>
                                </thead>

                                <tbody>
                                {% if sommeils is defined and sommeils|length > 0 %}
                                    {% for s in sommeils %}
                                        <tr
                                                data-id="{{ s.id }}"
                                                data-user="{{ s.user_label|lower }}"
                                                data-date="{{ s.date_nuit ? s.date_nuit|date('Y-m-d') : '' }}"
                                                data-duree="{{ s.duree }}"
                                                data-qualite="{{ s.qualite_label|lower }}"
                                                data-coucher="{{ s.heure_coucher }}"
                                                data-reveil="{{ s.heure_reveil }}"
                                                data-status="{{ s.statut_label|lower }}"
                                        >
                                            <td>{{ s.id }}</td>
                                            <td>{{ s.user_label }}</td>
                                            <td>{{ s.date_nuit ? s.date_nuit|date('d/m/Y') : '-' }}</td>
                                            <td>{{ s.duree }}h</td>
                                            <td>{{ s.qualite_label }}</td>
                                            <td>{{ s.heure_coucher }}</td>
                                            <td>{{ s.heure_reveil }}</td>
                                            <td>
                                                <span class="adm-status-badge {{ s.statut_class }}">
                                                    {{ s.statut_label }}
                                                </span>
                                            </td>
                                            <td class="adm-col-actions">
                                                <div class="adm-actions-group">
                                                    <a href="{{ path('app_sommeil_show', {'id': s.id}) }}" class="adm-btn adm-btn-sm adm-btn-blue">Voir</a>

                                                    <form method="post" action="{{ path('app_sommeil_delete', {'id': s.id}) }}" onsubmit="return confirm('Supprimer cette entrée ?');">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ s.id) }}">
                                                        <input type="hidden" name="_method" value="DELETE">
                                                        <button type="submit" class="adm-btn adm-btn-sm adm-btn-red">Supprimer</button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                {% else %}
                                    <tr>
                                        <td colspan="9" class="adm-empty-row">Aucune entrée sommeil.</td>
                                    </tr>
                                {% endif %}
                                </tbody>
                            </table>
                        </div>

                        {% if pagination_sommeils is defined and pagination_sommeils.pageCount > 1 %}
                            <div class="adm-pagination-wrap">
                                {{ knp_pagination_render(pagination_sommeils) }}
                            </div>
                        {% endif %}
                    </div>
                </section>

                <section class="adm-stacked-section">
                    <div class="adm-section-heading">
                        <h2 class="adm-section-block-title">Statistiques Rêves</h2>
                        <span class="adm-section-count">{{ kpis.total_reves }} rêve(s)</span>
                    </div>

                    <div class="adm-powerbi-card">
                        <div class="adm-powerbi-card-header">
                            <span class="adm-powerbi-card-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
                                    <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                                    <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
                                </svg>
                            </span>
                            <h3 class="adm-powerbi-card-title">Analyse Power BI — Rêves</h3>
                            <span class="adm-powerbi-badge">Power BI</span>
                        </div>

                        <div class="adm-powerbi-frame-wrapper">
                            <iframe
                                    title="reve"
                                    src="https://app.powerbi.com/reportEmbed?reportId=44ad7526-3b99-41e9-982b-426507d7ff64&autoAuth=true&ctid=604f1a96-cbe8-43f8-abbf-f8eaf5d85730"
                                    frameborder="0"
                                    allowfullscreen="true"
                                    loading="lazy"
                                    class="adm-powerbi-iframe">
                            </iframe>
                        </div>
                    </div>

                    <div class="adm-table-card">
                        <div class="adm-table-header">
                            <div class="adm-table-header-left">
                                <span class="adm-table-dot dot-reves"></span>
                                <h2 class="adm-table-title">Tableau Rêves</h2>
                                <span class="adm-table-count" id="dreamCount">{{ kpis.total_reves }} rêve(s)</span>
                            </div>

                            <div class="adm-table-header-right" style="gap: 0.75rem; flex-wrap: wrap;">
                                <div class="adm-search-mini">
                                    <input type="search" id="dreamSearch" placeholder="Rechercher..." aria-label="Rechercher un rêve">
                                </div>

                                <select id="dreamTypeFilter" class="adm-filter-select">
                                    <option value="">Tous les types</option>
                                    <option value="normal">Normal</option>
                                    <option value="lucide">Lucide</option>
                                    <option value="cauchemar">Cauchemar</option>
                                    <option value="prémonitoire">Prémonitoire</option>
                                </select>
                            </div>
                        </div>

                        <div class="adm-table-wrap">
                            <table class="adm-table" id="dreamTable">
                                <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Utilisateur</th>
                                    <th>Date</th>
                                    <th>Titre</th>
                                    <th>Type</th>
                                    <th>Humeur</th>
                                    <th class="adm-col-actions">Actions</th>
                                </tr>
                                </thead>

                                <tbody>
                                {% if reves is defined and reves|length > 0 %}
                                    {% for r in reves %}
                                        <tr
                                                data-id="{{ r.id }}"
                                                data-user="{{ r.user_label|lower }}"
                                                data-date="{{ r.date_nuit ? r.date_nuit|date('Y-m-d') : '' }}"
                                                data-title="{{ r.titre|lower }}"
                                                data-type="{{ r.type_reve|lower }}"
                                                data-humeur="{{ r.humeur|lower }}"
                                        >
                                            <td>{{ r.id }}</td>
                                            <td>{{ r.user_label }}</td>
                                            <td>{{ r.date_nuit ? r.date_nuit|date('d/m/Y') : '-' }}</td>
                                            <td><strong>{{ r.titre }}</strong></td>
                                            <td>{{ r.type_reve }}</td>
                                            <td>
                                                <span class="adm-emotion-tag {{ r.humeur_class }}">
                                                    {{ r.humeur }}
                                                </span>
                                            </td>
                                            <td class="adm-col-actions">
                                                <div class="adm-actions-group">
                                                    <a href="{{ path('app_reve_show', {'id': r.id}) }}" class="adm-btn adm-btn-sm adm-btn-blue">Voir</a>

                                                    <form method="post" action="{{ path('app_reve_delete', {'id': r.id}) }}" onsubmit="return confirm('Supprimer ce rêve ?');">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ r.id) }}">
                                                        <input type="hidden" name="_method" value="DELETE">
                                                        <button type="submit" class="adm-btn adm-btn-sm adm-btn-red">Supprimer</button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                {% else %}
                                    <tr>
                                        <td colspan="7" class="adm-empty-row">Aucun rêve enregistré.</td>
                                    </tr>
                                {% endif %}
                                </tbody>
                            </table>
                        </div>

                        {% if pagination_reves is defined and pagination_reves.pageCount > 1 %}
                            <div class="adm-pagination-wrap">
                                {{ knp_pagination_render(pagination_reves) }}
                            </div>
                        {% endif %}
                    </div>
                </section>

            </main>
        </div>
    </div>
{% endblock %}

{% block body_javascripts %}
    {{ parent() }}

    <script>
        (() => {
            function setupTable(config) {
                const table = document.getElementById(config.tableId);
                const tbody = table ? table.querySelector('tbody') : null;
                const searchInput = document.getElementById(config.searchId);
                const filterSelect = document.getElementById(config.filterId);
                const countEl = document.getElementById(config.countId);

                if (!table || !tbody) return;

                const getRows = () => Array.from(tbody.querySelectorAll('tr')).filter(
                    row => !row.querySelector('.adm-empty-state') && !row.classList.contains('adm-empty-row')
                );

                function updateCount() {
                    const visibleRows = getRows().filter(row => row.style.display !== 'none').length;
                    if (countEl) countEl.textContent = config.countLabel(visibleRows);
                }

                function applyFilters() {
                    const query = (searchInput?.value || '').trim().toLowerCase();
                    const filter = (filterSelect?.value || '').trim().toLowerCase();

                    getRows().forEach((row) => {
                        const haystack = config.searchFields.map(field => row.dataset[field] || '').join(' ').toLowerCase();
                        const filterValue = row.dataset[config.filterField] || '';
                        const matchSearch = !query || haystack.includes(query);
                        const matchFilter = !filter || filterValue.includes(filter);

                        row.style.display = (matchSearch && matchFilter) ? '' : 'none';
                    });

                    updateCount();
                }

                searchInput?.addEventListener('input', applyFilters);
                filterSelect?.addEventListener('change', applyFilters);

                applyFilters();
            }

            setupTable({
                tableId: 'sleepTable',
                searchId: 'sleepSearch',
                filterId: 'sleepStatusFilter',
                countId: 'sleepCount',
                filterField: 'status',
                searchFields: ['id', 'user', 'date', 'duree', 'qualite', 'coucher', 'reveil', 'status'],
                countLabel: (n) => `${n} entrée(s)`
            });

            setupTable({
                tableId: 'dreamTable',
                searchId: 'dreamSearch',
                filterId: 'dreamTypeFilter',
                countId: 'dreamCount',
                filterField: 'type',
                searchFields: ['id', 'user', 'date', 'title', 'type', 'humeur'],
                countLabel: (n) => `${n} rêve(s)`
            });
        })();
    </script>
{% endblock %}