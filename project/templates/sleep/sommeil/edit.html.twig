{% extends 'sleep/_layout.html.twig' %}
{% block title %}Modifier nuit — Sleep Tracker{% endblock %}

{% block sleep_content %}
    <nav class="breadcrumb">
        <a href="{{ path('app_sommeil_index') }}">Sommeil</a>
        <span class="breadcrumb__sep">›</span>
        <a href="{{ path('app_sommeil_show', {id: sommeil.id}) }}">
            {{ sommeil.dateNuit ? sommeil.dateNuit|date('d/m/Y') : '#' ~ sommeil.id }}
        </a>
        <span class="breadcrumb__sep">›</span>
        <span class="breadcrumb__current">Modifier</span>
    </nav>

    <header class="page-header">
        <div class="page-header__left">
            <h1 class="page-header__title">✏️ Modifier la nuit</h1>
            <p class="page-header__subtitle">
                {{ sommeil.dateNuit ? sommeil.dateNuit|date('d/m/Y') : '' }}
            </p>
        </div>
    </header>

    {% include 'sleep/sommeil/components/_form_modal.html.twig' with {
        form: form,
        sommeil: sommeil,
        modal_mode: false
    } %}
{% endblock %}