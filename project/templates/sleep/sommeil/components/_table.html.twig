{% import _self as helper %}

{% macro sort_link(label, field, filters) %}
    {% set currentSort = filters.sort|default('date_nuit') %}
    {% set currentDirection = filters.direction|default('DESC') %}
    {% set direction = (currentSort == field and currentDirection == 'ASC') ? 'DESC' : 'ASC' %}

    <a href="{{ path(app.request.attributes.get('_route'), app.request.query.all|merge({
        sort: field,
        direction: direction
    })) }}"
       class="rv-sort-link {{ currentSort == field ? 'active' : '' }}">
        <span>{{ label }}</span>
        <span class="rv-sort-icon">
            {% if currentSort == field %}
                {{ currentDirection == 'ASC' ? '↑' : '↓' }}
            {% else %}
                ⇅
            {% endif %}
        </span>
    </a>
{% endmacro %}

<div class="rv-table-card rv-table-card--pro">
    <div class="rv-table-head rv-table-head--pro">
        <div>
            <h3>Journal des nuits</h3>
            <p>{{ sommeils.getTotalItemCount is defined ? sommeils.getTotalItemCount : sommeils|length }} élément(s) enregistrés</p>
        </div>
    </div>

    {% if sommeils is empty %}
        <div class="rv-empty rv-empty--pro">
            <div class="rv-empty-icon rv-empty-icon--pro">🌙</div>
            <h3>Aucune nuit enregistrée</h3>
            <p>Commencez à suivre votre sommeil pour obtenir une vision plus claire de vos habitudes nocturnes.</p>
            <button type="button" class="rv-btn rv-btn-primary" onclick="openSommeilModal('{{ path('app_sommeil_new') }}')">
                Ajouter une nuit
            </button>
        </div>
    {% else %}
        <div class="rv-table-wrap rv-table-wrap--pro">
            <table class="rv-table rv-table--pro">
                <thead>
                <tr>
                    <th>{{ helper.sort_link('Date', 'date_nuit', filters) }}</th>
                    <th>Coucher</th>
                    <th>Réveil</th>
                    <th>{{ helper.sort_link('Durée', 'duree', filters) }}</th>
                    <th>{{ helper.sort_link('Qualité', 'qualite', filters) }}</th>
                    <th>Humeur réveil</th>
                    <th>Badges</th>
                    <th class="rv-col-actions">Actions</th>
                </tr>
                </thead>

                <tbody>
                {% for sommeil in sommeils %}
                    {% set qualityClass = {
                        'Excellente': 'rv-pill-type',
                        'Bonne': 'rv-pill-color',
                        'Moyenne': 'rv-pill-warning',
                        'Mauvaise': 'rv-pill-danger'
                    } %}

                    <tr>
                        <td class="rv-cell-title">
                            <div class="rv-title-stack">
                                <button
                                        type="button"
                                        class="rv-link-button rv-link-strong rv-link-strong--pro"
                                        onclick="openSommeilModal('{{ path('app_sommeil_show', {id: sommeil.id}) }}')"
                                >
                                    {{ sommeil.dateNuit ? sommeil.dateNuit|date('d/m/Y') : '—' }}
                                </button>

                                <div class="rv-row-meta">
                                    {% if sommeil.isSommeilInsuffisant %}
                                        <span class="rv-inline-badge rv-inline-badge--soft">Sommeil insuffisant</span>
                                    {% else %}
                                        {% if sommeil.updatedAt is defined and sommeil.updatedAt and sommeil.createdAt is defined and sommeil.createdAt and sommeil.updatedAt|date('Y-m-d H:i:s') != sommeil.createdAt|date('Y-m-d H:i:s') %}
                                            <span class="rv-row-meta-text">
                                                Modifié le {{ sommeil.updatedAt|date('d/m/Y à H:i') }}
                                            </span>
                                        {% elseif sommeil.createdAt is defined and sommeil.createdAt %}
                                            <span class="rv-row-meta-text">
                                                Enregistré le {{ sommeil.createdAt|date('d/m/Y à H:i') }}
                                            </span>
                                        {% else %}
                                            <span class="rv-row-meta-text">
                                                Nuit enregistrée
                                            </span>
                                        {% endif %}
                                    {% endif %}
                                </div>
                            </div>
                        </td>

                        <td>{{ sommeil.heureCoucher ?? '—' }}</td>
                        <td>{{ sommeil.heureReveil ?? '—' }}</td>

                        <td>
                            {% if sommeil.dureeSommeil %}
                                <span class="rv-pill rv-pill--pro rv-pill-muted">{{ sommeil.dureeSommeil }} h</span>
                            {% else %}
                                <span class="rv-text-muted">—</span>
                            {% endif %}
                        </td>

                        <td>
                            {% if sommeil.qualite %}
                                <span class="rv-pill rv-pill--pro {{ qualityClass[sommeil.qualite] ?? 'rv-pill-muted' }}">
                                    {{ sommeil.qualite }}
                                </span>
                            {% else %}
                                <span class="rv-pill rv-pill--pro rv-pill-muted">—</span>
                            {% endif %}
                        </td>

                        <td>
                            {% if sommeil.humeurReveil %}
                                <span class="rv-pill rv-pill--pro rv-pill-muted">{{ sommeil.humeurReveil }}</span>
                            {% else %}
                                <span class="rv-pill rv-pill--pro rv-pill-muted">—</span>
                            {% endif %}
                        </td>

                        <td>
                            {% if sommeil.isSommeilInsuffisant %}
                                <span class="rv-pill rv-pill--pro rv-pill-warning">Insuffisant</span>
                            {% else %}
                                <span class="rv-pill rv-pill--pro rv-pill-muted">RAS</span>
                            {% endif %}
                        </td>

                        <td>
                            <div class="rv-actions rv-actions--pro">
                                <button
                                        type="button"
                                        class="rv-action-btn rv-action-btn--neutral"
                                        onclick="openSommeilModal('{{ path('app_sommeil_show', {id: sommeil.id}) }}')"
                                        title="Voir"
                                >
                                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true">
                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                        <circle cx="12" cy="12" r="3"/>
                                    </svg>
                                </button>

                                <button
                                        type="button"
                                        class="rv-action-btn rv-action-btn--neutral"
                                        onclick="openSommeilModal('{{ path('app_sommeil_edit', {id: sommeil.id}) }}')"
                                        title="Modifier"
                                >
                                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                    </svg>
                                </button>

                                <button type="button"
                                        class="rv-action-btn rv-action-btn--danger"
                                        onclick="openDeleteModal(
                                                '{{ path('app_sommeil_delete', {id: sommeil.id}) }}',
                                                '{{ sommeil.dateNuit ? sommeil.dateNuit|date('d/m/Y')|escape('js') : sommeil.id }}',
                                                '{{ csrf_token('delete' ~ sommeil.id) }}'
                                                )"
                                        title="Supprimer">
                                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true">
                                        <polyline points="3 6 5 6 21 6"/>
                                        <path d="M19 6l-1 14H6L5 6"/>
                                        <path d="M9 6V4h6v2"/>
                                    </svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>

        {% if sommeils.getPageCount is defined and sommeils.getPageCount > 1 %}
            <div class="rv-pagination rv-pagination--pro">
                {{ knp_pagination_render(sommeils) }}
            </div>
        {% endif %}
    {% endif %}
</div>