<div id="deleteModal"
     style="
         position: fixed;
         inset: 0;
         z-index: 999999;
         display: none;
         align-items: center;
         justify-content: center;
         padding: 24px;
         background: rgba(10, 40, 45, 0.35);
         backdrop-filter: blur(4px);
     ">

    <div class="sl-delete-dialog"
         style="
             width: min(460px, 100%);
             background: #e9fbfc;
             border: 1px solid #b3ecf1;
             border-radius: 22px;
             padding: 28px;
             box-shadow: 0 24px 60px rgba(19, 97, 99, 0.25);
         ">

        <h2 style="margin: 0 0 12px; color: #06283a; font-size: 1.6rem; font-weight: 800;">
            Supprimer cette nuit ?
        </h2>

        <p id="deleteModalBody" style="margin: 0 0 20px; color: #06283a; font-size: 1rem;">
            Supprimer cette nuit ? Action irréversible.
        </p>

        <form id="deleteForm" method="post">
            <input type="hidden" name="_token" value="">

            <div style="display: flex; gap: 10px; justify-content: flex-start;">
                <button type="button"
                        class="rv-btn rv-btn--secondary"
                        onclick="closeDeleteModal()">
                    Annuler
                </button>

                <button type="submit"
                        class="rv-btn rv-btn--danger">
                    Supprimer
                </button>
            </div>
        </form>
    </div>
</div>