{% extends 'sleep/_layout.html.twig' %}
{% block title %}Nouveau rêve — Sleep Tracker{% endblock %}

{% block sleep_content %}
    <style>
        .reve-create-page {
            max-width: 1200px;
            margin: 0 auto;
        }

        .reve-create-page .breadcrumb {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 18px;
            font-size: 14px;
            color: #5f7d95;
        }

        .reve-create-page .breadcrumb a {
            color: #2a617d;
            text-decoration: none;
            font-weight: 600;
        }

        .reve-create-page .breadcrumb a:hover {
            text-decoration: underline;
        }

        .reve-create-page .breadcrumb__sep {
            color: #90a8b8;
        }

        .reve-create-page .breadcrumb__current {
            color: #7b8f9e;
            font-weight: 500;
        }

        .reve-create-page .page-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 16px;
            margin-bottom: 22px;
        }

        .reve-create-page .page-header__title {
            margin: 0;
            font-size: 2rem;
            line-height: 1.2;
            font-weight: 800;
            color: #123b5d;
        }

        .reve-create-page .page-header__subtitle {
            margin: 8px 0 0;
            font-size: 1.02rem;
            color: #6a8497;
        }

        .reve-create-page .reve-create-card {
            background: #ffffff;
            border: 1px solid #d7edf2;
            border-radius: 24px;
            padding: 24px;
            box-shadow: 0 14px 36px rgba(28, 73, 102, 0.08);
        }

        /* Corrige l'affichage du composant inclus hors modal */
        .reve-create-page .modal,
        .reve-create-page .dream-modal,
        .reve-create-page .sn-modal,
        .reve-create-page .modal-backdrop,
        .reve-create-page .overlay {
            position: static !important;
            inset: auto !important;
            background: transparent !important;
            width: 100% !important;
            height: auto !important;
            display: block !important;
            overflow: visible !important;
            padding: 0 !important;
        }

        .reve-create-page .modal-content,
        .reve-create-page .dream-modal__content,
        .reve-create-page .sn-modal__content,
        .reve-create-page .dialog,
        .reve-create-page .form-modal,
        .reve-create-page .form-card {
            width: 100% !important;
            max-width: 100% !important;
            margin: 0 !important;
            border: 0 !important;
            box-shadow: none !important;
            background: transparent !important;
            padding: 0 !important;
            overflow: visible !important;
        }

        .reve-create-page form {
            width: 100%;
        }

        .reve-create-page fieldset,
        .reve-create-page .card,
        .reve-create-page .section,
        .reve-create-page .form-section,
        .reve-create-page .sn-section,
        .reve-create-page .dream-section {
            background: #fdfefe;
            border: 1px solid #dbeef3;
            border-radius: 22px;
            padding: 22px 24px;
            margin-bottom: 18px;
            min-width: 0;
        }

        .reve-create-page legend,
        .reve-create-page h2,
        .reve-create-page h3,
        .reve-create-page .section-title,
        .reve-create-page .form-section__title {
            margin: 0 0 18px;
            color: #1e5678;
            font-size: 1.15rem;
            font-weight: 800;
        }

        .reve-create-page .row,
        .reve-create-page .grid,
        .reve-create-page .form-row,
        .reve-create-page .fields-row,
        .reve-create-page .two-cols,
        .reve-create-page .form-grid {
            display: grid !important;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 18px 24px;
            align-items: start;
        }

        .reve-create-page .col,
        .reve-create-page .field,
        .reve-create-page .form-group,
        .reve-create-page .form-field {
            min-width: 0;
            width: 100%;
        }

        .reve-create-page label {
            display: block;
            margin-bottom: 8px;
            color: #1a3144;
            font-size: 1rem;
            font-weight: 600;
        }

        .reve-create-page input[type="text"],
        .reve-create-page input[type="number"],
        .reve-create-page input[type="date"],
        .reve-create-page input[type="time"],
        .reve-create-page input[type="email"],
        .reve-create-page select,
        .reve-create-page textarea {
            width: 100% !important;
            min-height: 52px;
            padding: 12px 16px;
            border: 1px solid #bfe3ea;
            border-radius: 16px;
            background: #f9fdfe;
            color: #17324a;
            font-size: 1rem;
            box-sizing: border-box;
            outline: none;
            transition: border-color .2s ease, box-shadow .2s ease, background .2s ease;
        }

        .reve-create-page textarea {
            min-height: 120px;
            resize: vertical;
        }

        .reve-create-page input:focus,
        .reve-create-page select:focus,
        .reve-create-page textarea:focus {
            border-color: #7bc7d5;
            box-shadow: 0 0 0 4px rgba(123, 199, 213, 0.18);
            background: #ffffff;
        }

        .reve-create-page input[type="checkbox"],
        .reve-create-page input[type="radio"] {
            width: 18px;
            height: 18px;
            margin-right: 8px;
            accent-color: #e85b5b;
            vertical-align: middle;
        }

        .reve-create-page .checkbox,
        .reve-create-page .check-row,
        .reve-create-page .inline-check {
            display: flex;
            align-items: center;
            gap: 8px;
            min-height: 52px;
        }

        .reve-create-page .form-actions,
        .reve-create-page .actions,
        .reve-create-page .modal-actions,
        .reve-create-page .btn-row {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-top: 22px;
            flex-wrap: wrap;
        }

        .reve-create-page button,
        .reve-create-page .btn,
        .reve-create-page a.btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 46px;
            padding: 0 18px;
            border-radius: 14px;
            border: 1px solid transparent;
            font-weight: 700;
            font-size: .98rem;
            text-decoration: none;
            cursor: pointer;
            transition: all .2s ease;
        }

        .reve-create-page button[type="submit"],
        .reve-create-page .btn-primary,
        .reve-create-page .btn-save {
            background: linear-gradient(135deg, #123b5d, #2b6d8f);
            color: #fff;
            box-shadow: 0 10px 22px rgba(18, 59, 93, 0.18);
        }

        .reve-create-page button[type="submit"]:hover,
        .reve-create-page .btn-primary:hover,
        .reve-create-page .btn-save:hover {
            transform: translateY(-1px);
        }

        .reve-create-page .btn-secondary,
        .reve-create-page .btn-light,
        .reve-create-page .btn-cancel,
        .reve-create-page a[href] {
            border-color: #cde5eb;
        }

        @media (max-width: 900px) {
            .reve-create-page .row,
            .reve-create-page .grid,
            .reve-create-page .form-row,
            .reve-create-page .fields-row,
            .reve-create-page .two-cols,
            .reve-create-page .form-grid {
                grid-template-columns: 1fr !important;
            }

            .reve-create-page .reve-create-card {
                padding: 18px;
            }

            .reve-create-page fieldset,
            .reve-create-page .card,
            .reve-create-page .section,
            .reve-create-page .form-section,
            .reve-create-page .sn-section,
            .reve-create-page .dream-section {
                padding: 18px;
            }
        }
    </style>

    <div class="reve-create-page">
        <nav class="breadcrumb">
            <a href="{{ path('app_reve_index') }}">Rêves</a>
            <span class="breadcrumb__sep">›</span>
            <span class="breadcrumb__current">Nouveau rêve</span>
        </nav>

        <header class="page-header">
            <div class="page-header__left">
                <h1 class="page-header__title">💭 Nouveau rêve</h1>
                <p class="page-header__subtitle">Décrivez votre rêve avec le plus de détails possible</p>
            </div>
        </header>

        <div class="reve-create-card">
            {% include 'sleep/reve/components/_form_modal.html.twig' with {
                form: form,
                modal_mode: false
            } %}
        </div>
    </div>
{% endblock %}