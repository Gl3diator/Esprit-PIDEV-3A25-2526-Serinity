<div class="rv-delete-overlay" id="deleteModal" aria-hidden="true">
    <div class="rv-delete-dialog">
        <h2>Supprimer ce rêve ?</h2>

        <p id="deleteModalBody">
            Supprimer ce rêve ? Action irréversible.
        </p>

        <form id="deleteForm" method="post">
            <input type="hidden" name="_token" value="">

            <div class="rv-delete-actions">
                <button type="button"
                        class="rv-btn rv-btn--secondary"
                        onclick="closeDeleteModal()">
                    Annuler
                </button>

                <button type="submit"
                        class="rv-btn rv-btn--danger">
                    Supprimer
                </button>
            </div>
        </form>
    </div>
</div>