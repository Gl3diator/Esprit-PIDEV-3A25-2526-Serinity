{% extends 'sleep/_layout.html.twig' %}
{% block title %}Modifier — {{ reve.titre }} — Sleep Tracker{% endblock %}

{% block sleep_content %}
    <nav class="breadcrumb">
        {{ path('app_reve_index') }}Rêves</a>
