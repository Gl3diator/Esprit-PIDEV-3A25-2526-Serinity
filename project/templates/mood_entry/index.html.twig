{% extends 'base.html.twig' %}

{% block title %}Mood entries{% endblock %}

{% block body %}
    <div class="container mt-5 mb-6">
        <div class="row mb-4 align-items-center">
            <div class="col">
                <h1 class="display-4 mb-0">Mood entries</h1>
                <p class="text-muted mb-0">Track your mood, emotions, and influences over time.</p>
            </div>
            <div class="col text-right">
                <a href="{{ path('app_mood_entry_new') }}" class="btn btn-primary rounded-pill px-4">
                    Create new entry
                </a>
            </div>
        </div>

        {% for group in grouped_entries %}
            <div class="mb-3 mt-4">
                <h3 class="mb-0">{{ group.label }}</h3>
            </div>

            {% for mood_entry in group.entries %}
                <div class="card border-0 shadow-sm mb-4" style="border-radius: 1.25rem; background: #ffffff;">
                    <div class="card-body p-4">
                        <div class="row align-items-start">
                            <div class="col-md-9">
                                <div class="d-flex flex-wrap align-items-center mb-3">
                                    <h3 class="mb-0 mr-3">
                                        {% if mood_entry.momentType == 'DAY' %}
                                            Day
                                        {% else %}
                                            Moment
                                        {% endif %}
                                    </h3>

                                    <span class="badge badge-pill badge-info mr-2 px-3 py-2">
                                        {{ mood_entry.momentType }}
                                    </span>

                                    <span class="badge badge-pill badge-primary px-3 py-2">
                                        {{ mood_entry.moodLevel }}/5
                                    </span>
                                </div>

                                <div class="mb-3">
                                    <h5 class="text-muted mb-2">Emotions</h5>
                                    {% for emotion in mood_entry.emotions %}
                                        <span class="badge badge-secondary mr-1 mb-1 px-3 py-2" style="border-radius: 999px;">
                                            {{ emotion.name }}
                                        </span>
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endfor %}
                                </div>

                                <div class="mb-0">
                                    <h5 class="text-muted mb-2">Influences</h5>
                                    {% for influence in mood_entry.influences %}
                                        <span class="badge badge-default mr-1 mb-1 px-3 py-2" style="border-radius: 999px;">
                                            {{ influence.name }}
                                        </span>
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endfor %}
                                </div>
                            </div>

                            <div class="col-md-3 text-md-right mt-3 mt-md-0">
                                <a href="{{ path('app_mood_entry_show', {'id': mood_entry.id}) }}" class="btn btn-sm btn-info ">
                                    Show
                                </a>
                                <a href="{{ path('app_mood_entry_edit', {'id': mood_entry.id}) }}" class="btn btn-sm btn-secondary ">
                                    Edit
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        {% else %}
            <div class="card border-0 shadow-sm" style="border-radius: 1.25rem; background: #ffffff;">
                <div class="card-body text-center text-muted">
                    No records found.
                </div>
            </div>
        {% endfor %}
    </div>
{% endblock %}