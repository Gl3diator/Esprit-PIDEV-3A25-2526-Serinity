{{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

    {% if form_errors(form) %}
        <div class="alert alert-danger">
            {{ form_errors(form) }}
        </div>
    {% endif %}

    <div class="form-group">
        {{ form_label(form.momentType, 'Type', {'label_attr': {'class': 'form-control-label'}}) }}
        {{ form_widget(form.momentType, {'attr': {'class': 'form-control rounded-pill'}}) }}
        {% if form_errors(form.momentType) %}
            <div class="text-danger text-sm mt-2">
                {{ form_errors(form.momentType) }}
            </div>
        {% endif %}
    </div>

    <div class="form-group">
        {{ form_label(form.moodLevel, 'Mood level', {'label_attr': {'class': 'form-control-label'}}) }}
        {{ form_widget(form.moodLevel, {'attr': {'class': 'form-control rounded-pill'}}) }}
        {% if form_errors(form.moodLevel) %}
            <div class="text-danger text-sm mt-2">
                {{ form_errors(form.moodLevel) }}
            </div>
        {% endif %}
    </div>

    <div class="form-group">
        {{ form_label(form.emotions, 'Emotions', {'label_attr': {'class': 'form-control-label'}}) }}

        <div class="choice-group-box shadow-sm">
            {% for choice in form.emotions %}
                <div class="choice-pill-item">
                    {{ form_widget(choice, {'attr': {'class': 'choice-pill-input'}}) }}
                    {{ form_label(choice, null, {'label_attr': {'class': 'choice-pill-label'}}) }}
                </div>
            {% endfor %}
        </div>

        <small class="form-text text-muted">Select between 1 and 5 emotions.</small>

        {% if form_errors(form.emotions) %}
            <div class="text-danger text-sm mt-2">
                {{ form_errors(form.emotions) }}
            </div>
        {% endif %}
    </div>

    <div class="form-group">
        {{ form_label(form.influences, 'Influences', {'label_attr': {'class': 'form-control-label'}}) }}

        <div class="choice-group-box shadow-sm">
            {% for choice in form.influences %}
                <div class="choice-pill-item">
                    {{ form_widget(choice, {'attr': {'class': 'choice-pill-input'}}) }}
                    {{ form_label(choice, null, {'label_attr': {'class': 'choice-pill-label'}}) }}
                </div>
            {% endfor %}
        </div>

        <small class="form-text text-muted">Select between 1 and 5 influences.</small>

        {% if form_errors(form.influences) %}
            <div class="text-danger text-sm mt-2">
                {{ form_errors(form.influences) }}
            </div>
        {% endif %}
    </div>

    <div class="mt-4">
        <button class="btn btn-primary">
            {{ button_label|default('Save') }}
        </button>
    </div>

{{ form_end(form) }}