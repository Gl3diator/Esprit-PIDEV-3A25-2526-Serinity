{% extends 'front/base_front.html.twig' %}

{% block title %}Edit mood entry{% endblock %}
{% block front_title %}Edit mood entry{% endblock %}
{% block front_subtitle %}Update your mood entry and selected emotions or influences.{% endblock %}
{% block front_summary %}
    <h4 class="text-white mb-2">Edit mood entry</h4>
    <p class="mb-0">Adjust the entry if your reflection needs correction.</p>
{% endblock %}

{% block front_content %}
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card serinity-surface-card shadow-sm mb-4">
                <div class="card-header border-0 bg-white">
                    <div class="row align-items-center">
                        <div class="col">
                            <h3 class="mb-0">Edit mood entry</h3>
                        </div>
                        <div class="col text-right">
                            <a href="{{ path('app_mood_entry_index') }}" class="btn btn-sm btn-outline-primary">
                                Back to list
                            </a>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4">
                    {{ include('mood_entry/_form.html.twig', {'button_label': 'Update'}) }}
                </div>
            </div>

            <div class="card serinity-surface-card shadow-sm">
                <div class="card-body">
                    {{ include('mood_entry/_delete_form.html.twig') }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}