{% extends 'base.html.twig' %}

{% block title %}Edit mood entry{% endblock %}

{% block body %}
    <div class="container mt-5 mb-6">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="card border-0 shadow-sm mb-4" style="border-radius: 1.25rem; background: #ffffff;">
                    <div class="card-header border-0 bg-white" style="border-radius: 1.25rem 1.25rem 0 0;">
                        <div class="row align-items-center">
                            <div class="col">
                                <h3 class="mb-0">Edit mood entry</h3>
                            </div>
                            <div class="col text-right">
                                <a href="{{ path('app_mood_entry_index') }}" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                    Back to list
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="card-body p-4">
                        {{ include('mood_entry/_form.html.twig', {'button_label': 'Update'}) }}
                    </div>
                </div>

                <div class="card border-0 shadow-sm" style="border-radius: 1.25rem; background: #ffffff;">
                    <div class="card-body">
                        {{ include('mood_entry/_delete_form.html.twig') }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}