{% extends 'admin/base_admin.html.twig' %}

{% block title %}Admin dashboard{% endblock %}

{% block admin_content %}
    <div class="row">
        <div class="col-xl-6 mb-4">
            <div class="card shadow h-100">
                <div class="card-body">
                    <h5 class="text-uppercase text-muted mb-3">Lookup management</h5>
                    <h2 class="mb-3">Emotions</h2>
                    <p class="text-muted mb-4">
                        Add, update, and review the emotion list used in mood entries.
                    </p>
                    <a href="{{ path('app_admin_emotion_index') }}" class="btn btn-primary">
                        Manage emotions
                    </a>
                </div>
            </div>
        </div>

        <div class="col-xl-6 mb-4">
            <div class="card shadow h-100">
                <div class="card-body">
                    <h5 class="text-uppercase text-muted mb-3">Lookup management</h5>
                    <h2 class="mb-3">Influences</h2>
                    <p class="text-muted mb-4">
                        Add, update, and review the influence list used in mood entries.
                    </p>
                    <a href="{{ path('app_admin_influence_index') }}" class="btn btn-primary">
                        Manage influences
                    </a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}