{% extends 'admin/base_admin.html.twig' %}

{% block title %}Edit emotion{% endblock %}

{% block admin_content %}
    <div class="card shadow mb-4">
        <div class="card-header border-0">
            <div class="row align-items-center">
                <div class="col">
                    <h3 class="mb-0">Edit emotion</h3>
                </div>
                <div class="col text-right">
                    <a href="{{ path('app_admin_emotion_index') }}" class="btn btn-sm btn-outline-primary">
                        Back to list
                    </a>
                </div>
            </div>
        </div>

        <div class="card-body">
            {{ include('admin/emotion/_form.html.twig', {'button_label': 'Update'}) }}
        </div>
    </div>

    <div class="card shadow">
        <div class="card-body">
            {{ include('admin/emotion/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}