{% extends 'base.html.twig' %}

{% block title %}Journal entries{% endblock %}

{% block body %}
    <div class="container mt-5 mb-6">
        <div class="row mb-4 align-items-center">
            <div class="col">
                <h1 class="display-4 mb-0">Journal entries</h1>
                <p class="text-muted mb-0">Write and review your personal reflections.</p>
            </div>
            <div class="col text-right">
                <a href="{{ path('app_journal_entry_new') }}" class="btn btn-primary ">
                    Create new entry
                </a>
            </div>
        </div>

        {% for group in grouped_entries %}
            <div class="mb-3 mt-4">
                <h3 class="mb-0">{{ group.label }}</h3>
            </div>

            {% for journal_entry in group.entries %}
                <div class="card border-0 shadow-sm mb-4" style="border-radius: 1.25rem; background: #ffffff;">
                    <div class="card-body p-4">
                        <div class="row align-items-start">
                            <div class="col-md-9">
                                <h3 class="mb-2">{{ journal_entry.title }}</h3>

                                <p class="text-muted mb-0">
                                    {{ journal_entry.content|length > 220
                                        ? journal_entry.content|slice(0, 220) ~ '...'
                                        : journal_entry.content }}
                                </p>
                            </div>

                            <div class="col-md-3 text-md-right mt-3 mt-md-0">
                                <a href="{{ path('app_journal_entry_show', {'id': journal_entry.id}) }}" class="btn btn-sm btn-info ">
                                    Show
                                </a>
                                <a href="{{ path('app_journal_entry_edit', {'id': journal_entry.id}) }}" class="btn btn-sm btn-secondary ">
                                    Edit
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        {% else %}
            <div class="card border-0 shadow-sm" style="border-radius: 1.25rem; background: #ffffff;">
                <div class="card-body text-center text-muted">
                    No journal entries found.
                </div>
            </div>
        {% endfor %}
    </div>
{% endblock %}