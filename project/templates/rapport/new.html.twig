{% extends 'base.html.twig' %}

{% block body %}

<div class="container mt-5">

    <div class="card shadow-lg border-0 rounded-4">

        <!-- HEADER -->
        <div class="card-header bg-white border-0 rounded-top-4">
            <h4 class="mb-0 fw-bold text-success">
                <i class="bi bi-journal-plus"></i> Ajouter une Consultation
            </h4>
            <small class="text-muted">Remplissez les informations ci-dessous</small>
        </div>

        <!-- BODY -->
        <div class="card-body p-4">

            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

            <div class="mb-3">
                <label class="form-label fw-semibold">
                    <i class="bi bi-heart-pulse"></i> Diagnostic
                </label>
                {{ form_widget(form.diagnostic, {'attr': {'class': 'form-control rounded-3'}}) }}
                {{ form_errors(form.diagnostic) }}
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">
                    <i class="bi bi-capsule"></i> Prescription
                </label>
                {{ form_widget(form.prescription, {'attr': {'class': 'form-control rounded-3'}}) }}
                {{ form_errors(form.prescription) }}
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">
                    <i class="bi bi-journal-text"></i> Notes
                </label>
                {{ form_widget(form.notes, {'attr': {'class': 'form-control rounded-3'}}) }}
                {{ form_errors(form.notes) }}
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold">
                    <i class="bi bi-calendar-check"></i> Rendez-vous
                </label>
                {{ form_widget(form.rendezVous, {'attr': {'class': 'form-select rounded-3'}}) }}
                {{ form_errors(form.rendezVous) }}
            </div>

            <!-- BUTTON -->
            <div class="d-flex justify-content-end gap-2">
                 

                <button class="btn btn-success rounded-pill px-4">
                    <i class="bi bi-check-circle"></i> Enregistrer
                </button>
            </div>

            {{ form_end(form) }}

        </div>
    </div>

</div>

{% endblock %}