{% extends 'base.html.twig' %}

{% block body %}

<style>
.card-report {
    border-radius: 20px;
    box-shadow: 0 15px 40px rgba(0,0,0,0.05);
    border: none;
}

.avatar-lg {
    width:60px;
    height:60px;
    border-radius:50%;
    background:linear-gradient(135deg,#2F6F6D,#88BDBC);
    color:white;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:22px;
    font-weight:bold;
}

.consultation-card {
    border-radius: 16px;
    border-left: 5px solid #2F6F6D;
    transition: 0.2s;
}

.consultation-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.05);
}

.section-title {
    font-weight: 600;
    color: #2F6F6D;
}
</style>

<div class="container mt-4">

    <!-- HEADER -->
    <div class="card card-report p-4 mb-4">

        <div class="d-flex align-items-center gap-3">

            <div class="avatar-lg">
                {{ rapport.patient.fullName|slice(0,1) }}
            </div>

            <div>
                <h5 class="mb-0">
                    <i class="bi bi-person-circle"></i>
                    {{ rapport.patient.fullName }}
                </h5>
                <small class="text-muted">
                    <i class="bi bi-file-medical"></i>
                    Rapport médical
                </small>
            </div>

        </div>

    </div>


    <!-- CONSULTATIONS -->
    <div class="card card-report p-4">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h6 class="section-title mb-0">
                <i class="bi bi-clipboard2-pulse"></i> Consultations
            </h6>

            <a href="{{ path('app_consultation_new', {id: rapport.id}) }}"
               class="btn btn-success btn-sm rounded-pill">
                <i class="bi bi-plus-circle"></i> Ajouter
            </a>
        </div>

 
            {% for c in consultations %}
                <div class="consultation-card p-3 mb-3 bg-light">

                    <div class="d-flex justify-content-between mb-2">
                        <small class="text-muted">
                            <i class="bi bi-calendar-event"></i>
                            {{ c.dateConsultation|date('d/m/Y H:i') }}
                        </small>

                        <span class="badge bg-success">
                            <i class="bi bi-check-circle"></i> Consultation
                        </span>
                    </div>

                    <div class="mb-2">
                        <strong><i class="bi bi-heart-pulse"></i> Diagnostic:</strong>
                        <div class="text-muted">{{ c.diagnostic ?: 'Non renseigné' }}</div>
                    </div>

                    <div class="mb-2">
                        <strong><i class="bi bi-capsule"></i> Prescription:</strong>
                        <div class="text-muted">{{ c.prescription ?: 'Non renseigné' }}</div>
                    </div>

                    <div>
                        <strong><i class="bi bi-journal-text"></i> Notes:</strong>
                        <div class="text-muted">{{ c.notes ?: 'Aucune note' }}</div>
                    </div>

                    <div class="d-flex gap-2 mt-3">
                        <a href="{{ path('app_consultation_edit', {id: c.id}) }}"
                           class="btn btn-sm btn-outline-primary rounded-pill">
                            <i class="bi bi-pencil-square"></i> Modifier
                        </a>

                        <a href="{{ path('app_consultation_delete', {id: c.id}) }}"
                           class="btn btn-sm btn-outline-danger rounded-pill"
                           onclick="return confirm('Supprimer cette consultation ?');">
                            <i class="bi bi-trash"></i> Supprimer
                        </a>
                    </div>

                </div>
            {% else %}

            <div class="text-center text-muted py-4">
                <i class="bi bi-clipboard-x" style="font-size:30px;"></i>
                <p class="mt-2">Aucune consultation pour ce patient</p>
            </div>

        {% endfor %}

    </div>

</div>

{% endblock %}