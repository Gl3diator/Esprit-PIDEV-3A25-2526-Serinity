{% extends 'base.html.twig' %}

{% block title %}Influence index{% endblock %}

{% block body %}
    <h1>Influence index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for influence in influences %}
            <tr>
                <td>{{ influence.id }}</td>
                <td>{{ influence.name }}</td>
                <td>
                    <a href="{{ path('app_influence_show', {'id': influence.id}) }}">show</a>
                    <a href="{{ path('app_influence_edit', {'id': influence.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_influence_new') }}">Create new</a>
{% endblock %}
