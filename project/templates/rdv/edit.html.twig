{% extends 'baseclient.html.twig' %}

{% block title %}Modifier Rendez-vous{% endblock %}

{% block body %}

<style>
.rdv-container {
    max-width: 850px;
    margin: 50px auto;
}

.rdv-card {
    background: #fff;
    border-radius: 20px;
    padding: 30px;
    box-shadow: 0 10px 35px rgba(0,0,0,0.05);
}

.rdv-header {
    display: flex;
    align-items: center;
    gap: 15px;
    margin-bottom: 25px;
}

.avatar {
    width: 65px;
    height: 65px;
    border-radius: 50%;
    background: linear-gradient(135deg,#2F6F6D,#88BDBC);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 22px;
    font-weight: bold;
}

.doctor-info {
    line-height: 1.2;
}

.doctor-name {
    font-size: 18px;
    font-weight: 600;
}

.doctor-spec {
    font-size: 13px;
    color: #2F6F6D;
}

.form-group {
    margin-bottom: 18px;
}

.form-label {
    font-weight: 500;
    margin-bottom: 5px;
}

.form-control {
    border-radius: 10px;
    padding: 10px;
    border: 1px solid #ddd;
}

.btn-submit {
    background: #2F6F6D;
    color: white;
    border-radius: 12px;
    padding: 12px;
    width: 100%;
    border: none;
    font-weight: 600;
    transition: 0.2s;
}

.btn-submit:hover {
    background: #255d5b;
}

.btn-back {
    display: block;
    text-align: center;
    margin-top: 15px;
    background: #F0F7F6;
    color: #2F6F6D;
    padding: 10px;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 500;
}

.btn-back:hover {
    background: #e1f0ee;
}

.text-danger {
    font-size: 13px;
    margin-top: 4px;
}
</style>

<div class="rdv-container">

    <div class="rdv-card">

        <div class="rdv-header">
            <div class="avatar">
                {{ doctor.fullName|slice(0,1) }}
            </div>

            <div class="doctor-info">
                <div class="doctor-name">
                    {{ doctor.fullName }}
                </div>
                <div class="doctor-spec">
                    {{ doctor.speciality ?? 'Medecin Generaliste' }}
                </div>
            </div>
        </div>

        <h5 class="mb-3">
            <i class="bi bi-pencil-square"></i>
            Modifier le rendez-vous
        </h5>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}

        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

        <div class="form-group">
            {{ form_label(form.dateTime, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.dateTime, {'attr': {'class': 'form-control'}}) }}
            <div class="text-danger">{{ form_errors(form.dateTime) }}</div>
        </div>

        <div class="form-group">
            {{ form_label(form.motif, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.motif, {'attr': {'class': 'form-control'}}) }}
            <div class="text-danger">{{ form_errors(form.motif) }}</div>
        </div>

        <div class="form-group">
            {{ form_label(form.description, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 3}}) }}
            <div class="text-danger">{{ form_errors(form.description) }}</div>
        </div>

        <button class="btn-submit">
            <i class="bi bi-check-circle"></i> Enregistrer les modifications
        </button>

        {{ form_end(form) }}

        <a href="{{ path('app_patient_rdv') }}" class="btn-back">
            <i class="bi bi-arrow-left"></i> Retour
        </a>

    </div>

</div>

{% endblock %}
