{% extends 'access_control/layout.html.twig' %}

{% block title %}Détail du Rendez-vous | Serinity{% endblock %}

{% block content %}
<div class="ac-app-layout">

    {% include 'access_control/components/_sidebar.html.twig' with { items: nav } %}

    <div class="ac-main" data-controller="flash-toast">

        {% include 'access_control/components/_topbar.html.twig' with {
            title: 'Détail Rendez-vous',
            subtitle: 'Suivi de votre consultation',
            username: userName
        } %}

        {% for message in app.flashes('success') %}
            <span data-flash-toast-target="message" data-type="success" hidden>{{ message }}</span>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <span data-flash-toast-target="message" data-type="error" hidden>{{ message }}</span>
        {% endfor %}

        <section class="ac-card rdv-shell">

<style>
.rdv-shell{
    max-width:820px;
    margin:auto;
    padding:1.4rem;
}

.rdv-header{
    display:flex;
    align-items:center;
    gap:1rem;
    margin-bottom:1.4rem;
    padding-bottom:1rem;
    border-bottom:1px solid #eef2f7;
}

.rdv-avatar{
    width:68px;
    height:68px;
    border-radius:50%;
    display:flex;
    align-items:center;
    justify-content:center;
    color:#fff;
    font-size:1.2rem;
    font-weight:800;
    background:linear-gradient(135deg,#2F6F6D,#57a7a3);
    flex-shrink:0;
}

.rdv-name{
    margin:0;
    font-size:1.15rem;
    font-weight:800;
    color:#0f172a;
}

.rdv-sub{
    color:#64748b;
    margin-top:.2rem;
    font-size:.9rem;
}

.status-wrap{
    margin-bottom:1rem;
}

.badge-status{
    display:inline-flex;
    align-items:center;
    gap:.45rem;
    padding:.55rem .9rem;
    border-radius:999px;
    font-size:.74rem;
    font-weight:800;
}

.status-wait{
    background:#fff7ed;
    color:#ea580c;
}

.status-ok{
    background:#ecfdf5;
    color:#16a34a;
}

.status-refused{
    background:#fef2f2;
    color:#dc2626;
}

.info-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(230px,1fr));
    gap:.9rem;
    margin-bottom:1rem;
}

.info-card{
    background:#f8fafc;
    border:1px solid #eef2f7;
    border-radius:18px;
    padding:1rem;
}

.info-label{
    font-size:.75rem;
    color:#94a3b8;
    text-transform:uppercase;
    letter-spacing:.04em;
    font-weight:700;
    margin-bottom:.35rem;
}

.info-value{
    color:#0f172a;
    font-weight:700;
}

.box{
    background:#fff;
    border:1px solid #eef2f7;
    border-radius:18px;
    padding:1rem;
    margin-bottom:.9rem;
}

.box-title{
    font-size:.76rem;
    color:#94a3b8;
    text-transform:uppercase;
    letter-spacing:.04em;
    font-weight:700;
    margin-bottom:.45rem;
}

.box-content{
    color:#0f172a;
    font-weight:600;
    line-height:1.55;
}

.action-row{
    display:flex;
    gap:.8rem;
    flex-wrap:wrap;
    margin-top:1.2rem;
}

.btn-back{
    padding:.92rem 1.15rem;
    border-radius:14px;
    font-weight:700;
    text-decoration:none;
    color:#334155;
    background:#f8fafc;
    border:1px solid #e2e8f0;
    transition:.2s;
}

.btn-back:hover{
    transform:translateY(-2px);
}
</style>

{% set doctorName = rdv.doctor.fullName is defined and rdv.doctor.fullName ? rdv.doctor.fullName : rdv.doctor.email %}

<div class="rdv-header">

    <div class="rdv-avatar">
        {{ doctorName|slice(0,1)|upper }}
    </div>

    <div>
        <h3 class="rdv-name">{{ doctorName }}</h3>
        <div class="rdv-sub">
            Informations de votre rendez-vous
        </div>
    </div>

</div>

<div class="status-wrap">

    <span class="badge-status
        {% if rdv.status == 'EN_ATTENTE' %}status-wait
        {% elseif rdv.status == 'VALIDE' %}status-ok
        {% else %}status-refused{% endif %}
    ">

        {% if rdv.status == 'EN_ATTENTE' %}
            <i class="bi bi-hourglass-split"></i>
        {% elseif rdv.status == 'VALIDE' %}
            <i class="bi bi-check-circle-fill"></i>
        {% else %}
            <i class="bi bi-x-circle-fill"></i>
        {% endif %}

        {{ rdv.status }}

    </span>

</div>

<div class="info-grid">

    <div class="info-card">
        <div class="info-label">Date du rendez-vous</div>
        <div class="info-value">
            {{ rdv.dateTime|date('d/m/Y H:i') }}
        </div>
    </div>

    <div class="info-card">
        <div class="info-label">Médecin / Thérapeute</div>
        <div class="info-value">
            {{ doctorName }}
        </div>
    </div>

</div>

<div class="box">
    <div class="box-title">Motif</div>
    <div class="box-content">
        {{ rdv.motif ?: 'Sans motif' }}
    </div>
</div>

<div class="box">
    <div class="box-title">Description</div>
    <div class="box-content">
        {{ rdv.description ?: 'Aucune description fournie.' }}
    </div>
</div>

{% if rdv.proposedDateTime %}
<div class="box">
    <div class="box-title">Nouvelle date proposée</div>
    <div class="box-content">
        {{ rdv.proposedDateTime|date('d/m/Y H:i') }}
    </div>
</div>
{% endif %}

{% if rdv.doctorNote %}
<div class="box">
    <div class="box-title">Note du thérapeute</div>
    <div class="box-content">
        {{ rdv.doctorNote }}
    </div>
</div>
{% endif %}

<div class="action-row">

    <a href="{{ path('app_patient_rdv') }}" class="btn-back">
        <i class="bi bi-arrow-left"></i>
        Retour
    </a>

</div>

        </section>

    </div>
</div>
{% endblock %}