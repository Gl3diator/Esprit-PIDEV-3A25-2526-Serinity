{% extends 'base.html.twig' %}

{% block title %}Serinity{% endblock %}

{% block body %}
    {% set currentRoute = app.request.attributes.get('_route') %}

    <div class="serinity-hero">
        <nav class="navbar navbar-expand-lg navbar-dark pt-4 serinity-navbar">
            <div class="container">
                <a class="navbar-brand serinity-brand" href="{{ path('app_home') }}">
                    <img
                        src="{{ asset('argon/img/serinity-logo.png') }}"
                        alt="Serinity logo"
                        class="serinity-brand-logo"
                    >
                    <span class="serinity-brand-text">SERINITY</span>
                </a>

                <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#frontNavbar" aria-controls="frontNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="frontNavbar">
                    <ul class="navbar-nav ml-4">
                        <li class="nav-item">
                            <a class="nav-link serinity-nav-link {% if currentRoute starts with 'app_mood_entry_' and currentRoute != 'app_mood_entry_summary' %}active{% endif %}"
                               href="{{ path('app_mood_entry_index') }}">
                                <i class="ni ni-satisfied mr-2"></i>
                                Mood entries
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link serinity-nav-link {% if currentRoute == 'app_mood_entry_summary' %}active{% endif %}"
                               href="{{ path('app_mood_entry_summary') }}">
                                <i class="ni ni-chart-bar-32 mr-2"></i>
                                Mood summary
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link serinity-nav-link {% if currentRoute starts with 'app_journal_entry_' %}active{% endif %}"
                               href="{{ path('app_journal_entry_index') }}">
                                <i class="ni ni-single-copy-04 mr-2"></i>
                                Journal
                            </a>
                        </li>
                    </ul>

                    <ul class="navbar-nav align-items-lg-center ml-lg-auto">
                        <li class="nav-item d-none d-lg-block">
                            <span class="serinity-top-badge">
                                <i class="ni ni-chart-bar-32 mr-2"></i>
                                Mood Control
                            </span>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

        <div class="container mt-5">
            <div class="row align-items-center">
                <div class="col-lg-7">
                    <h1 class="display-3 text-white mb-3">{% block front_title %}Serinity{% endblock %}</h1>
                    <p class="lead text-white-75 mb-0">
                        {% block front_subtitle %}Your personal space for mood tracking and reflection.{% endblock %}
                    </p>
                </div>

                <div class="col-lg-5 mt-4 mt-lg-0">
                    <div class="serinity-glass-card p-4 shadow">
                        {% block front_summary %}
                            <h4 class="text-white mb-2">Mood Control</h4>
                            <p class="mb-0">Track mood entries, review influences, and write journal reflections.</p>
                        {% endblock %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container serinity-page-wrap mb-6">
        {% block front_content %}{% endblock %}
    </div>
    <footer class="serinity-landing-footer">
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-lg-12 text-center">
                        <p class="mb-0">© 2026 Serinity. All rights reserved.</p>
                    </div>
                </div>
            </div>
        </footer>
{% endblock %}