{% extends 'base.html.twig' %}

{% block title %}Serinity{% endblock %}

{% block body %}
    <div class="serinity-hero">
        <nav class="navbar navbar-expand-lg serinity-navbar">
            <div class="container">
                <a class="navbar-brand" href="{{ path('app_mood_entry_index') }}">SERINITY</a>

                <div class="collapse navbar-collapse show">
                    <ul class="navbar-nav mr-auto ml-4">
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_mood_entry_index') }}">Mood</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_journal_entry_index') }}">Journal</a>
                        </li>
                    </ul>

                    <span class="navbar-text">Mood Control</span>
                </div>
            </div>
        </nav>

        <div class="container mt-5">
            <div class="row align-items-center">
                <div class="col-lg-7">
                    <h1 class="display-3 text-white mb-3">{% block front_title %}Serinity{% endblock %}</h1>
                    <p class="lead text-white-75 mb-0">
                        {% block front_subtitle %}Your personal space for mood tracking and reflection.{% endblock %}
                    </p>
                </div>

                <div class="col-lg-5 mt-4 mt-lg-0">
                    <div class="serinity-glass-card p-4 shadow">
                        {% block front_summary %}
                            <h4 class="text-white mb-2">Mood Control</h4>
                            <p class="mb-0">Track mood entries, review influences, and write journal reflections.</p>
                        {% endblock %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container serinity-page-wrap mb-6">
        {% block front_content %}{% endblock %}
    </div>
{% endblock %}