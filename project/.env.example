###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change-me
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# Format described at https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url
# IMPORTANT: You MUST configure your server version, either here or in config/packages/doctrine.yaml
DATABASE_URL="mysql://db_user:db_password@127.0.0.1:3306/serinity?serverVersion=10.11.0-MariaDB&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
# Choose one of the transports below
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> Redis server ###
# REDIS_URL=redis://127.0.0.1:6379
###< Redis server ###

# ========================================================================
# ======================== ACCESS_CONTROL_SECRETS ========================
# ========================================================================

###> symfony/mailer ###
PHPMAILER_HOST=smtp.gmail.com
PHPMAILER_PORT=587
PHPMAILER_USERNAME=your_smtp_username
PHPMAILER_PASSWORD=your_smtp_password
PHPMAILER_ENCRYPTION=tls
PHPMAILER_FROM_EMAIL=noreply@serinity.org
PHPMAILER_FROM_NAME=Serinity
PASSWORD_RESET_CODE_TTL_MINUTES=15
PASSWORD_RESET_RATE_LIMIT_ATTEMPTS=5
PASSWORD_RESET_RATE_LIMIT_WINDOW_SECONDS=900
PASSWORD_RESET_MAX_RESENDS=3
EMAIL_VERIFICATION_CODE_TTL_MINUTES=15
EMAIL_VERIFICATION_RATE_LIMIT_ATTEMPTS=5
EMAIL_VERIFICATION_RATE_LIMIT_WINDOW_SECONDS=900
EMAIL_VERIFICATION_MAX_RESENDS=3
###< symfony/mailer ###

###> knpuniversity/oauth2-client-bundle ###
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/auth/google/callback
###< knpuniversity/oauth2-client-bundle ###

###> face-auth/onnx ###
FACE_AUTH_SIMILARITY_THRESHOLD=0.30
FACE_AUTH_RATE_LIMIT_ATTEMPTS=5
FACE_AUTH_RATE_LIMIT_WINDOW_SECONDS=900
FACE_AUTH_RECOGNITION_MODEL_PATH=public/antelopev2/glintr100.onnx
FACE_AUTH_ONNX_RUNTIME_LIBRARY_PATH=vendor/ankane/onnxruntime/lib/onnxruntime-linux-x64-1.24.3/lib/libonnxruntime.so.1.24.3
FACE_AUTH_PYTHON_COMMAND=.venv/bin/python
FACE_AUTH_PYTHON_SCRIPT_PATH=bin/face_embedding_infer.py
FACE_AUTH_INPUT_WIDTH=112
FACE_AUTH_INPUT_HEIGHT=112
###< face-auth/onnx ###

###> google/2FA ###
TWO_FACTOR_CHALLENGE_TTL_SECONDS=300
TWO_FACTOR_RATE_LIMIT_ATTEMPTS=5
TWO_FACTOR_RATE_LIMIT_WINDOW_SECONDS=900
###< google/2FA ###

###> avatar/img2img ###
AVATAR_IMG2IMG_API_URL=http://127.0.0.1:7860
AVATAR_IMG2IMG_TIMEOUT=180
AVATAR_DEFAULT_PROMPT="anime portrait, high quality, soft lighting, detailed face, studio lighting"
AVATAR_DEFAULT_NEGATIVE_PROMPT="blurry, low quality, distorted face, extra limbs, bad anatomy"
AVATAR_DEFAULT_STRENGTH=0.65
AVATAR_RATE_LIMIT_ATTEMPTS=10
AVATAR_RATE_LIMIT_WINDOW_SECONDS=900
AVATAR_GENERATION_PENDING_TTL_SECONDS=180
###< avatar/img2img ###

###> Image api ###
IMAGE_REQUEST_URL=https://freeimage.host/api/1/upload
IMAGE_API_KEY=your_image_api_key
###< Image api ###

###> User risk detection api ###
USER_RISK_DETECTION_URL=http://127.0.0.1:8003
USER_RISK_API_TIMEOUT=15
USER_RISK_CACHE_TTL_SECONDS=1800
###< User risk detection Api ###

###> security/ban ###
ACCOUNT_BAN_DURATION_MINUTES=1
###< security/ban ###

